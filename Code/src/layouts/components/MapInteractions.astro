  function buildGridLinks(computeResult) {
    const out = [];
    if (!computeResult || !Array.isArray(computeResult.residuals)) return out;
    computeResult.residuals.forEach((res) => {
      if (!res || !res.old || !res.new) return;
      const oldCoord = {
        lat: Number(res.old.y),
        lng: Number(res.old.x),
      };
      const newCoord = {
        lat: Number(res.new.y),
        lng: Number(res.new.x),
      };
      out.push({
        name: res.name || "",
        new: newCoord,
        old: oldCoord,
