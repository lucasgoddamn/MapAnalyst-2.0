---

---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>
<style>
  .leaflet-marker-icon.marker-red {
    filter: hue-rotate(145deg) saturate(3.5) brightness(1) !important;
  }
  .leaflet-marker-icon.marker-green {
    filter: hue-rotate(90deg) saturate(2) brightness(1.5) !important;
  }
  .suggestion-ghost-marker {
    pointer-events: auto;
  }
  .suggestion-popup {
    min-width: 180px;
  }
  .suggestion-popup button {
    background: #1d4ed8;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 12px;
    padding: 4px 8px;
    cursor: pointer;
  }
  .suggestion-popup button.btn-reject {
    background: #b91c1c;
  }
  .suggestion-popup button.btn-focus {
    background: #6b7280;
  }
  .suggestion-popup button:not(:last-child) {
    margin-right: 6px;
  }
</style>

<script type="module">
  import L from "https://cdn.skypack.dev/leaflet";

  // ---------- ICONS ----------
  delete L.Icon.Default.prototype._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconRetinaUrl:
      "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png",
    iconUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png",
    shadowUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
  });
  const DefaultIconClass = L.Icon.Default;
  const RedIcon = DefaultIconClass.extend({
    options: { className: "marker-red" },
  });
  const GreenIcon = DefaultIconClass.extend({
    options: { className: "marker-green" },
  });

  // ---------- STATE ----------
  let oldMapInstance = null,
    newMapInstance = null;
  let mode = null;
  const oldMarkers = [],
    newMarkers = [],
    selectedMarkers = new Set(),
    links = [];
  const suggestedLinks = [];
  let suggestionState = {
    status: "idle", // idle | loading | ready | error
    message: "",
    error: null,
    requestId: 0,
    mode: "bulk",
    items: suggestedLinks,
    startedAt: null,
    diagnostics: null,
  };
  let suggestionAbortController = null;
  const mapSources = {
    old: { type: "upload", filename: null, width: null, height: null },
    new: {
      type: "osm",
      filename: null,
      width: null,
      height: null,
      tileset: "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
    },
  };
  const OSM_TILE_URL = "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png";
  const OSM_ATTRIBUTION = "© OpenStreetMap contributors";
  let newOsmBaseLayer = null;
  let newOsmFallbackLayer = null;
  let baseTileFallbackApplied = false;
  let lastOldUploadFilename = null;
  let lastNewUploadFilename = null;
  let lastOldStoredPath = null;
  let lastNewStoredPath = null;
  const suggestionLayers = { old: null, new: null };
  const suggestionMarkerRefs = { old: new Map(), new: new Map() };
  let activeSuggestionPopup = null;
  let highlightedSuggestionId = null;
  const SUGGESTION_MARKER_STYLE = {
    radius: 6,
    weight: 2,
  };
  const SUGGESTION_MARKER_HIGHLIGHT = {
    radius: 8,
    weight: 3,
  };
  let suggestionConfig = {
    minDistance: 250,
    maxSuggestions: 50,
    color: "#f97316",
  };
  function adjustColor(hex, amount = 0) {
    const norm = normalizeHexColor(hex, "#f97316");
    const num = parseInt(norm.slice(1), 16);
    let r = (num >> 16) & 255;
    let g = (num >> 8) & 255;
    let b = num & 255;
    r = Math.min(255, Math.max(0, Math.round(r + 255 * amount)));
    g = Math.min(255, Math.max(0, Math.round(g + 255 * amount)));
    b = Math.min(255, Math.max(0, Math.round(b + 255 * amount)));
    return `#${((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1)}`;
  }

  function ensureSuggestionLayers() {
    if (oldMapInstance && !suggestionLayers.old) {
      suggestionLayers.old = L.layerGroup().addTo(oldMapInstance);
    }
    if (newMapInstance && !suggestionLayers.new) {
      suggestionLayers.new = L.layerGroup().addTo(newMapInstance);
    }
  }

  function clearSuggestionLayers() {
    ["old", "new"].forEach((key) => {
      const layer = suggestionLayers[key];
      if (layer) layer.clearLayers();
      suggestionMarkerRefs[key]?.clear?.();
    });
    highlightedSuggestionId = null;
    if (activeSuggestionPopup) {
      try {
        activeSuggestionPopup.remove();
      } catch (_err) {}
      activeSuggestionPopup = null;
    }
  }

  function renderSuggestionMarkers() {
    if (!oldMapInstance || !newMapInstance) return;
    ensureSuggestionLayers();
    clearSuggestionHighlight();
    if (activeSuggestionPopup) {
      try {
        activeSuggestionPopup.remove();
      } catch (_err) {}
      activeSuggestionPopup = null;
    }
    clearSuggestionLayers();
    if (!Array.isArray(suggestedLinks) || !suggestedLinks.length) return;

    suggestedLinks.forEach((suggestion) => {
      if (suggestion?.old) {
        const marker = createSuggestionMarker("old", suggestion, suggestion.old);
        if (marker) suggestionMarkerRefs.old.set(suggestion.id, marker);
      }
      if (suggestion?.new) {
        const marker = createSuggestionMarker("new", suggestion, suggestion.new);
        if (marker) suggestionMarkerRefs.new.set(suggestion.id, marker);
      }
    });
  }

  function createSuggestionMarker(mapKey, suggestion, coords) {
    const map = mapKey === "old" ? oldMapInstance : newMapInstance;
    const layer = suggestionLayers[mapKey];
    if (!map || !layer || !coords) return null;
    const baseColor = suggestion?.color || suggestionConfig.color || "#f97316";
    const color =
      mapKey === "old" ? baseColor : adjustColor(baseColor, 0.2);
    const marker = L.circleMarker([coords.lat, coords.lng], {
      radius: SUGGESTION_MARKER_STYLE.radius,
      weight: SUGGESTION_MARKER_STYLE.weight,
      color,
      opacity: 0.95,
      fillOpacity: 0.35,
      fillColor: color,
      className: "suggestion-ghost-marker",
    }).addTo(layer);
    marker.on("click", (ev) => {
      ev.originalEvent?.preventDefault?.();
      ev.originalEvent?.stopPropagation?.();
      highlightSuggestionPair(suggestion.id);
      openSuggestionPopup(suggestion.id, mapKey);
    });
    marker.on("mouseover", () => highlightSuggestionPair(suggestion.id));
    marker.on("mouseout", () => {
      if (!activeSuggestionPopup) clearSuggestionHighlight();
    });
    return marker;
  }

  function openSuggestionPopup(suggestionId, mapKey) {
    const suggestion = suggestedLinks.find((s) => s.id === suggestionId);
    if (!suggestion) return;
    const map = mapKey === "old" ? oldMapInstance : newMapInstance;
    const marker = suggestionMarkerRefs[mapKey]?.get?.(suggestionId);
    if (!map || !marker) return;

    const container = document.createElement("div");
    container.className = "suggestion-popup";
    container.innerHTML = `
      <div style="font-size:13px;font-weight:600;margin-bottom:4px;">${suggestion.name || "Suggested Link"}</div>
      <div style="font-size:11px;color:#6b7280;margin-bottom:8px;">Source: ${suggestion.source || "auto"}</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;">
        <button type="button" class="btn-accept">Accept</button>
        <button type="button" class="btn-reject">Dismiss</button>
        <button type="button" class="btn-focus">Show</button>
      </div>
    `;

    container.querySelector(".btn-accept")?.addEventListener("click", (ev) => {
      ev.preventDefault();
      acceptSuggestionById(suggestionId);
      map.closePopup(activeSuggestionPopup);
    });
    container.querySelector(".btn-reject")?.addEventListener("click", (ev) => {
      ev.preventDefault();
      rejectSuggestionById(suggestionId);
      map.closePopup(activeSuggestionPopup);
    });
    container.querySelector(".btn-focus")?.addEventListener("click", (ev) => {
      ev.preventDefault();
      focusSuggestionOnMaps(suggestion);
    });

    const popup = L.popup({
      className: "suggestion-popup",
      closeButton: true,
      autoPan: true,
    })
      .setLatLng(marker.getLatLng())
      .setContent(container)
      .openOn(map);

    activeSuggestionPopup = popup;
    popup.on("remove", () => {
      if (activeSuggestionPopup === popup) activeSuggestionPopup = null;
    });
  }

  function focusSuggestionOnMaps(suggestion) {
    if (oldMapInstance && suggestion.old) {
      oldMapInstance.panTo([suggestion.old.lat, suggestion.old.lng], { animate: true });
    }
    if (newMapInstance && suggestion.new) {
      newMapInstance.panTo([suggestion.new.lat, suggestion.new.lng], { animate: true });
    }
  }

  function highlightSuggestionPair(id) {
    if (highlightedSuggestionId === id) return;
    clearSuggestionHighlight();
    highlightedSuggestionId = id;
    ["old", "new"].forEach((key) => {
      const marker = suggestionMarkerRefs[key]?.get?.(id);
      if (marker?.setStyle) {
        marker.setStyle({
          ...SUGGESTION_MARKER_HIGHLIGHT,
          color: marker.options.color,
          fillColor: marker.options.fillColor,
        });
      }
    });
  }

  function clearSuggestionHighlight() {
    if (!highlightedSuggestionId) return;
    ["old", "new"].forEach((key) => {
      const marker = suggestionMarkerRefs[key]?.get?.(highlightedSuggestionId);
      if (marker?.setStyle) {
        marker.setStyle({
          ...SUGGESTION_MARKER_STYLE,
          color: marker.options.color,
          fillColor: marker.options.fillColor,
        });
      }
    });
    highlightedSuggestionId = null;
  }

  window.addEventListener("mapanalyst:open-suggestion-config", (ev) => {
    openSuggestionConfigModal(ev?.detail?.source || "toolbar");
  });
  let suggestionSystemInitialized = false;

  function ensureSuggestionSystem() {
    if (suggestionSystemInitialized) return;
    suggestionSystemInitialized = true;
    window.addEventListener("mapanalyst:update-links-ui", handleSuggestionUiUpdate);
    window.addEventListener("mapanalyst:request-suggestions", handleSuggestionRequest);
  }

  const handleSuggestionUiUpdate = () => {
    requestAnimationFrame(() => renderSuggestionMarkers());
  };

  function openSuggestionConfigModal(source = "toolbar") {
    ensureSuggestionSystem();
    document.getElementById("suggestion-config-modal")?.remove();
    const html = `
      <div class="fixed inset-0 z-[99998] flex items-center justify-center bg-black/50" id="suggestion-config-modal">
        <div class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 rounded-xl shadow-2xl w-full max-w-md p-6 space-y-4 relative">
          <button class="absolute top-2 right-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" id="suggestion-config-close" aria-label="Close">✕</button>
          <h2 class="text-xl font-semibold">Suggested Links Settings</h2>
          <div class="space-y-3">
            <label class="block text-sm font-medium">Minimum distance between suggestions (m for OSM, px for image refs)</label>
            <input type="number" min="0" step="10" id="suggestion-config-min-dist" class="w-full rounded border border-gray-300 dark:border-gray-700 bg-transparent px-3 py-2" value="${suggestionConfig.minDistance || 0}" />
          </div>
          <div class="space-y-3">
            <label class="block text-sm font-medium">Maximum number of suggestions</label>
            <input type="number" min="1" max="80" step="1" id="suggestion-config-max-count" class="w-full rounded border border-gray-300 dark:border-gray-700 bg-transparent px-3 py-2" value="${suggestionConfig.maxSuggestions || 50}" />
          </div>
          <div class="space-y-3">
            <label class="block text-sm font-medium">Marker color</label>
            <input type="color" id="suggestion-config-color" class="w-16 h-10 p-1 border border-gray-300 dark:border-gray-700 rounded" value="${normalizeHexColor(suggestionConfig.color || "#f97316")}" />
          </div>
          <div class="flex justify-end gap-3 pt-2">
            <button type="button" id="suggestion-config-cancel" class="px-4 py-2 rounded border border-gray-300 dark:border-gray-700 text-sm">Cancel</button>
            <button type="button" id="suggestion-config-apply" class="px-4 py-2 rounded bg-indigo-600 hover:bg-indigo-500 text-white text-sm">Compute suggested links</button>
          </div>
        </div>
      </div>
    `;
    document.body.insertAdjacentHTML("beforeend", html);
    const modal = document.getElementById("suggestion-config-modal");
    const close = () => modal?.remove();
    modal.querySelector("#suggestion-config-close")?.addEventListener("click", close);
    modal.querySelector("#suggestion-config-cancel")?.addEventListener("click", close);
    modal.addEventListener("mousedown", (ev) => {
      if (ev.target?.id === "suggestion-config-modal") close();
    });
    modal.querySelector("#suggestion-config-apply")?.addEventListener("click", () => {
      const minDist = Number(document.getElementById("suggestion-config-min-dist")?.value) || 0;
      const maxCount = Number(document.getElementById("suggestion-config-max-count")?.value) || suggestionConfig.maxSuggestions;
      const color = document.getElementById("suggestion-config-color")?.value || suggestionConfig.color;
      suggestionConfig = {
        minDistance: Math.max(0, minDist),
        maxSuggestions: Math.max(1, Math.min(80, maxCount)),
        color: normalizeHexColor(color, suggestionConfig.color),
      };
      close();
      renderSuggestionMarkers();
      requestSuggestionsWithConfig(source);
    });
  }

  function requestSuggestionsWithConfig(source = "toolbar") {
    ensureSuggestionSystem();
    window.dispatchEvent(
      new CustomEvent("mapanalyst:request-suggestions", {
        detail: {
          mode: "bulk",
          showModal: true,
          source,
          config: {
            minDistance: suggestionConfig.minDistance,
            maxSuggestions: suggestionConfig.maxSuggestions,
          },
        },
      })
    );
  }

  const polygonStates = {
    old: createPolygonState("old"),
    new: createPolygonState("new"),
  };
  let currentTargetMap = "old";
  let lastSettingsSnapshot = null;
  let distortionGridGroup = null;
  let undistortedGridGroup = null;
  let distortionGridData = null;
  let lastGridPayloadKey = null;
  let gridFetchController = null;
  let lastComputeResult = null;
  let distortionGridMapKey = null;
  let undistortedGridMapKey = null;
  let extentWarningShown = false;
  let lastValidExtentValue = "rectangular";
  let gridTransformToOld = null;
  let displacementGroup = null;
  let displacementMapKey = null;
  let isolineScaleGroup = null;
  let isolineRotationGroup = null;
  let isolineMapKey = null;
  let isolineData = null;
  let lastIsolinePayloadKey = null;
  let isolineFetchController = null;
  let oldMapDefaultBounds = null;
  let newMapDefaultBounds = null;
  let newMapDefaultView = { center: [20, 0], zoom: 2 };
  const DEFAULT_CIRCLE_AREA_BOOST = 50;
  const markerAppearance = {
    old: { size: 1, opacity: 1 },
    new: { size: 1, opacity: 1 },
  };
  let markerAppearanceTarget = "both";
  const BASE_ICON_SIZE =
    L.Icon.Default.prototype.options?.iconSize || [25, 41];
  const BASE_ICON_ANCHOR =
    L.Icon.Default.prototype.options?.iconAnchor || [
      BASE_ICON_SIZE[0] / 2,
      BASE_ICON_SIZE[1],
    ];
  const BASE_SHADOW_SIZE =
    L.Icon.Default.prototype.options?.shadowSize || [41, 41];
  const BASE_SHADOW_ANCHOR =
    L.Icon.Default.prototype.options?.shadowAnchor || BASE_ICON_ANCHOR.slice();

  // expose for other UIs (toolbar / modals)
  window.getLinks = () => links;
  window.getSuggestedLinks = () => suggestedLinks;
  window.getSuggestionState = () => ({
    ...suggestionState,
    items: [...suggestedLinks],
  });

  function updateMapSource(mapKey, partial) {
    if (!mapSources[mapKey]) mapSources[mapKey] = { type: "unknown" };
    mapSources[mapKey] = {
      ...mapSources[mapKey],
      ...partial,
      type: partial?.type || mapSources[mapKey].type || "unknown",
    };
  }

  function getMapSource(mapKey) {
    return { ...(mapSources[mapKey] || {}) };
  }

  function emitLinkStateChanged() {
    window.dispatchEvent(new CustomEvent("mapanalyst:update-links-ui"));
  }

  function emitSuggestionStateChanged() {
    window.dispatchEvent(new CustomEvent("mapanalyst:update-links-ui"));
  }

  function setSuggestionState(partial) {
    suggestionState = { ...suggestionState, ...partial };
    emitSuggestionStateChanged();
  }

  function clearSuggestions(reason = "reset") {
    if (suggestionAbortController) {
      suggestionAbortController.abort();
      suggestionAbortController = null;
    }
    suggestedLinks.splice(0, suggestedLinks.length);
    setSuggestionState({
      status: "idle",
      message: reason === "data-changed" ? "Suggestions cleared after recent edits." : "",
      error: null,
      startedAt: null,
      diagnostics: null,
    });
    clearSuggestionLayers();
  }

  function replaceSuggestions(newItems, meta = {}) {
    const mapped = Array.isArray(newItems)
      ? newItems.map((item) => ({
          ...item,
          color: item?.color || suggestionConfig.color,
        }))
      : [];
    suggestedLinks.splice(0, suggestedLinks.length, ...mapped);
    setSuggestionState({
      status: "ready",
      message: meta.message || "",
      error: null,
      mode: meta.mode || suggestionState.mode,
      requestId: meta.requestId ?? suggestionState.requestId,
      startedAt: meta.startedAt ?? suggestionState.startedAt,
      diagnostics: meta.diagnostics ?? suggestionState.diagnostics ?? null,
    });
  }

  function removeSuggestionById(id) {
    const idx = suggestedLinks.findIndex((s) => s?.id === id);
    if (idx >= 0) {
      suggestedLinks.splice(idx, 1);
      emitSuggestionStateChanged();
    }
  }

  function getMapViewSummary(mapKey) {
    const map = getLeafletMap(mapKey);
    if (!map) return null;
    const center = map.getCenter?.();
    const bounds = map.getBounds?.();
    const size = map.getSize?.();
    return {
      zoom: map.getZoom?.() ?? null,
      center: center
        ? { lat: center.lat, lng: center.lng }
        : null,
      bounds: bounds
        ? {
            north: bounds.getNorth(),
            south: bounds.getSouth(),
            east: bounds.getEast(),
            west: bounds.getWest(),
          }
        : null,
      pixelSize: size ? { x: size.x, y: size.y } : null,
      minZoom: map.getMinZoom?.() ?? null,
      maxZoom: map.getMaxZoom?.() ?? null,
      crs: map.options?.crs?.code || map.options?.crs?.name || null,
    };
  }

  function normalizeLatLngCandidate(value) {
    if (!value || typeof value !== "object") return null;
    const latRaw =
      value.lat ??
      value.latitude ??
      value.y ??
      (Array.isArray(value) ? value[0] : null);
    const lngRaw =
      value.lng ??
      value.longitude ??
      value.x ??
      (Array.isArray(value) ? value[1] : null);
    const lat = Number(latRaw);
    const lng = Number(lngRaw);
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
    return { lat, lng };
  }

  function normalizeSuggestionEntry(entry, idx = 0) {
    if (!entry || typeof entry !== "object") return null;
    const oldPt = normalizeLatLngCandidate(entry.old ?? entry.old_point);
    const newPt = normalizeLatLngCandidate(entry.new ?? entry.new_point);
    if (!oldPt || !newPt) return null;
    const id =
      entry.id ||
      entry.uuid ||
      `suggestion-${Date.now()}-${Math.random().toString(16).slice(2)}-${idx}`;
    return {
      id,
      name: entry.name || entry.label || `Suggestion ${idx + 1}`,
      score:
        Number.isFinite(Number(entry.score))
          ? Number(entry.score)
          : Number(entry.confidence ?? entry.weight ?? 0),
      source: entry.source || entry.kind || "visual",
      old: oldPt,
      new: newPt,
      meta: entry.meta || {},
      preview: entry.preview || null,
    };
  }

  
  function buildSuggestionPayload(options = {}) {
    const mode = options.mode || "bulk";
    const baseState =
      (typeof window.mapanalystGetState === "function" &&
        window.mapanalystGetState()) || {
        oldPoints: [],
        newPoints: [],
        links: [],
        polygons: {
          old: getPolygonCoordinates("old"),
          new: getPolygonCoordinates("new"),
          target: currentTargetMap,
          selectedKey: getSelectedPolygonKey(),
        },
      };
    const polygons = {
      old: getPolygonCoordinates("old"),
      new: getPolygonCoordinates("new"),
      target: currentTargetMap,
      selectedKey: getSelectedPolygonKey(),
    };
    const constraintInput = options.constraints || {};
    const minDistance =
      typeof constraintInput.minDistance === "number"
        ? constraintInput.minDistance
        : suggestionConfig.minDistance;
    const maxSuggestions =
      typeof constraintInput.maxSuggestions === "number"
        ? constraintInput.maxSuggestions
        : suggestionConfig.maxSuggestions;
    return {
      mode,
      request: {
        created_at: Date.now(),
        hints: options.hints || {},
        focus: options.focus || null,
        source: options.source || null,
      },
      state: {
        ...baseState,
        polygons,
      },
      map_sources: {
        old: getMapSource("old"),
        new: getMapSource("new"),
      },
      view: {
        old: getMapViewSummary("old"),
        new: getMapViewSummary("new"),
      },
      constraints: {
        min_distance: Number(minDistance) || 0,
        max_suggestions: Number(maxSuggestions) || 0,
      },
    };
  }
function acceptSuggestionById(id, options = {}) {
    const idx = suggestedLinks.findIndex((s) => s?.id === id);
    if (idx < 0) return false;
    const suggestion = suggestedLinks[idx];
    if (!suggestion?.old || !suggestion?.new) return false;
    if (!oldMapInstance || !newMapInstance) return false;

    const oldMarker = L.marker(L.latLng(suggestion.old.lat, suggestion.old.lng), {
      icon: new GreenIcon(),
      draggable: false,
    }).addTo(oldMapInstance);
    hookMarker(oldMarker, oldMarkers, true);
    oldMarkers.push(oldMarker);

    const newMarker = L.marker(L.latLng(suggestion.new.lat, suggestion.new.lng), {
      icon: new GreenIcon(),
      draggable: false,
    }).addTo(newMapInstance);
    hookMarker(newMarker, newMarkers, false);
    newMarkers.push(newMarker);

    selectedMarkers.clear();
    selectedMarkers.add(oldMarker);
    selectedMarkers.add(newMarker);

    links.push({
      old: oldMarker,
      new: newMarker,
      name:
        suggestion.name ||
        suggestion.meta?.name ||
        `Suggestion ${links.length + 1}`,
      __suggestionId: suggestion.id,
      score: suggestion.score ?? null,
      source: suggestion.source || "visual",
    });

    suggestedLinks.splice(idx, 1);
    updateMarkerStyles();
    pushHistory();
    emitLinkStateChanged();
    emitSuggestionStateChanged();
    if (options?.notify !== false) {
      setSuggestionState({
        message:
          suggestedLinks.length > 0
            ? `${suggestedLinks.length} suggestion${
                suggestedLinks.length === 1 ? "" : "s"
              } remaining.`
            : "All suggestions reviewed.",
      });
    }
    return true;
  }

  function rejectSuggestionById(id, reason = "user") {
    const idx = suggestedLinks.findIndex((s) => s?.id === id);
    if (idx < 0) return false;
    suggestedLinks.splice(idx, 1);
    emitSuggestionStateChanged();
    if (reason === "user") {
      setSuggestionState({
        message:
          suggestedLinks.length > 0
            ? `${suggestedLinks.length} suggestion${
                suggestedLinks.length === 1 ? "" : "s"
              } remaining.`
            : "",
      });
    }
    return true;
  }

  
  async function handleSuggestionRequest(ev) {
    const detail = ev?.detail || {};
    const mode = detail.mode || "bulk";
    const requestId = (suggestionState.requestId ?? 0) + 1;

    if (suggestionAbortController) {
      suggestionAbortController.abort();
    }
    const controller = new AbortController();
    suggestionAbortController = controller;

    setSuggestionState({
      status: "loading",
      message: detail.message || "Preparing suggestion request...",
      error: null,
      requestId,
      mode,
      startedAt: Date.now(),
      diagnostics: null,
    });

    const payload = buildSuggestionPayload({
      mode,
      hints: detail.hints || {},
      focus: detail.focus || null,
      source: detail.source || null,
      constraints: detail.config || null,
    });

    if (detail.showModal === true && !document.getElementById("linked-points-modal")) {
      window.dispatchEvent(new CustomEvent("mapanalyst:show-links", { detail: { source: detail.source || "request", autoOpen: true } }));
    } else {
      emitSuggestionStateChanged();
    }

    try {
      const response = await fetch("http://localhost:8000/api/suggest_links", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
        signal: controller.signal,
      });
      if (!response.ok) {
        const text = await response.text();
        throw new Error(text || `Suggestion request failed (${response.status})`);
      }
      const data = await response.json();
      if (data?.diagnostics) {
        console.info("[MapAnalyst][suggestions]", data.diagnostics);
      }
      const suggestionsRaw = Array.isArray(data?.suggestions)
        ? data.suggestions
        : [];
      const normalized = suggestionsRaw
        .map((entry, idx) => normalizeSuggestionEntry(entry, idx))
        .filter(Boolean);
      replaceSuggestions(normalized, {
        message:
          data?.message ||
          (normalized.length
            ? `${normalized.length} suggestion${normalized.length === 1 ? "" : "s"} ready.`
            : "No suggestions found for the current selection."),
        requestId,
        mode,
        startedAt: suggestionState.startedAt,
        diagnostics: data?.diagnostics || null,
      });
      if (detail.showModal !== false) {
        window.dispatchEvent(
          new CustomEvent("mapanalyst:show-links", {
            detail: { source: detail.source || "auto-result" },
          })
        );
      }
    } catch (error) {
      if (controller.signal.aborted) {
        setSuggestionState({
          status: "idle",
          message: "Suggestion request cancelled.",
          error: null,
          requestId,
          diagnostics: null,
        });
      } else {
        console.error("[suggestions] request failed", error);
        setSuggestionState({
          status: "error",
          message: "",
          error: error?.message || "Failed to compute suggestions.",
          requestId,
          diagnostics: null,
        });
      }
    } finally {
      if (suggestionAbortController === controller) {
        suggestionAbortController = null;
      }
    }
  }
