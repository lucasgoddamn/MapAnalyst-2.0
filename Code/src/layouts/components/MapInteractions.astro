  }

  function normalizeHexColor(color, fallback = "#444444") {
    if (typeof color !== "string") return fallback;
    let hex = color.trim();
    if (/^#[0-9a-f]{3}$/i.test(hex)) {
      hex =
        "#" +
        hex
          .slice(1)
          .split("")
