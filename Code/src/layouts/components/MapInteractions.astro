  // =====================================================================
  //                          IMPORT / EXPORT
  // =====================================================================

  // Generic text parser -> arrays of number tuples
  function readText(fileOrString) {
    return new Promise((resolve, reject) => {
      if (typeof fileOrString === "string") return resolve(fileOrString);
      if (!(fileOrString instanceof File))
        return reject(new Error("No file supplied"));
      if (!/\.txt$/i.test(fileOrString.name))
        return reject(new Error("Only .txt files are supported"));
      const reader = new FileReader();
      reader.onload = (e) => resolve(String(e.target.result || ""));
      reader.onerror = () => reject(new Error("Failed to read file"));
      reader.readAsText(fileOrString);
    });
  }

  function parsePairs(txt) {
    const out = [];
    txt.split(/\r?\n/).forEach((line) => {
      const clean = line.trim();
      if (!clean || clean.startsWith("#") || clean.startsWith("//")) return;
      const nums = clean
        .replace(/[,;]+/g, " ")
        .split(/\s+/)
        .map(Number)
        .filter((n) => Number.isFinite(n));
      if (nums.length >= 2) out.push([nums[0], nums[1]]);
    });
    return out;
  }

  function parseLinked(txt) {
    const out = [];
    txt.split(/\r?\n/).forEach((line) => {
      const clean = line.trim();
      if (!clean || clean.startsWith("#") || clean.startsWith("//")) return;
      // Allow: oldX oldY newLat newLng [name...]
      const parts = clean.replace(/[,;]+/g, " ").split(/\s+/);
      const nums = parts.slice(0, 4).map(Number);
      if (nums.length >= 4 && nums.every(Number.isFinite)) {
        const name = parts.length > 4 ? parts.slice(4).join(" ") : "";
        out.push({
          oldX: nums[0],
          oldY: nums[1],
          newLat: nums[2],
          newLng: nums[3],
          name,
        });
      }
    });
    return out;
  }

  // ---- IMPORT (Old / New / Linked) ----
  async function importOldPointsFromFile(fileOrString) {
    try {
      const txt = await readText(fileOrString);
      const pairs = parsePairs(txt); // [x,y] in pixels (CRS.Simple: [lat=y,lng=x])
      pairs.forEach(([x, y]) =>
        addPoint(oldMapInstance, L.latLng(y, x), oldMarkers)
      );
      updateMarkerStyles();
      pushHistory();
      clearSuggestions("data-changed");
      alert(`Imported ${pairs.length} point(s) for Old Map.`);
    } catch (err) {
      alert(err.message || "Failed to import old points");
    }
  }

  async function importNewPointsFromFile(fileOrString) {
    try {
      const txt = await readText(fileOrString);
      const pairs = parsePairs(txt); // [lng,lat]
      pairs.forEach(([lng, lat]) =>
        addPoint(newMapInstance, L.latLng(lat, lng), newMarkers)
      );
      updateMarkerStyles();
      pushHistory();
      clearSuggestions("data-changed");
      alert(`Imported ${pairs.length} point(s) for New Map.`);
    } catch (err) {
      alert(err.message || "Failed to import new points");
    }
  }

  async function importLinkedPointsFromFile(fileOrString) {
    try {
      const txt = await readText(fileOrString);
      const rows = parseLinked(txt);
      rows.forEach((r) => {
        // create two new markers
        const oldM = L.marker(L.latLng(r.oldY, r.oldX), {
          icon: new RedIcon(),
          draggable: false,
        }).addTo(oldMapInstance);
        const newM = L.marker(L.latLng(r.newLat, r.newLng), {
          icon: new RedIcon(),
          draggable: false,
        }).addTo(newMapInstance);
        hookMarker(oldM, oldMarkers, true);
        hookMarker(newM, newMarkers, false);
        oldMarkers.push(oldM);
        newMarkers.push(newM);

        // enforce 1:1
        for (let i = links.length - 1; i >= 0; i--)
          if (links[i].old === oldM || links[i].new === newM)
            links.splice(i, 1);

        links.push({
          old: oldM,
          new: newM,
          name: r.name || `Link ${links.length + 1}`,
        });
      });
      updateMarkerStyles();
      pushHistory();
      emitLinkStateChanged();
      clearSuggestions("data-changed");
      alert(`Imported ${rows.length} linked pair(s).`);
    } catch (err) {
      alert(err.message || "Failed to import linked points");
    }
  }

  // Expose for toolbar (single router)
  window.mapanalystImport = (kind, file) => {
    if (kind === "old") return importOldPointsFromFile(file);
    if (kind === "new") return importNewPointsFromFile(file);
    if (kind === "linked") return importLinkedPointsFromFile(file);
    alert("Unknown import type");
  };

  // ---- EXPORT HELPERS ----
  function downloadText(filename, text) {
    const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    setTimeout(() => {
      URL.revokeObjectURL(a.href);
      a.remove();
    }, 0);
  }

  // ---- EXPORT FORMATS ----
  function exportOldPointsTxt() {
    const lines = ["# Old Map points (x y, pixels)"];
    oldMarkers.forEach((m) => {
      const { lat, lng } = m.getLatLng();
      lines.push(`${lng} ${lat}`);
    });
    downloadText("old_points.txt", lines.join("\n"));
  }

  function exportNewPointsTxt() {
    const lines = ["# New Map points (lng lat)"];
    newMarkers.forEach((m) => {
      const { lat, lng } = m.getLatLng();
      lines.push(`${lng} ${lat}`);
    });
    downloadText("new_points.txt", lines.join("\n"));
  }

  // Linked: oldX oldY newLat newLng [name]
  function exportLinkedPointsTxt() {
    const lines = ["# Linked points: oldX oldY newLat newLng name"];
    links.forEach((l) => {
      const { lat: oy, lng: ox } = l.old.getLatLng();
      const { lat: nlat, lng: nlng } = l.new.getLatLng();
      lines.push(`${ox} ${oy} ${nlat} ${nlng} ${l.name || ""}`.trim());
    });
    downloadText("linked_points.txt", lines.join("\n"));
  }

  // Extra (kept available if you later add UI entries)
  function exportLinkedWithVectorsInNewMapTxt() {
    const lines = [
      "# Linked points with vectors in New Map",
      "# Columns: oldX oldY newLat newLng dx dy (dx,dy placeholders)",
    ];
    links.forEach((l) => {
      const { lat: oy, lng: ox } = l.old.getLatLng();
      const { lat: nlat, lng: nlng } = l.new.getLatLng();
      const dx = 0,
        dy = 0;
      lines.push(`${ox} ${oy} ${nlat} ${nlng} ${dx} ${dy}`);
    });
    downloadText("linked_points_vectors_new_map.txt", lines.join("\n"));
  }
  function exportLinkedOldPixelsNewMetersTxt() {
    const lines = [
      "# Linked points: old in pixels, new in meters (meters need computed scale)",
      "# Columns: oldX(px) oldY(px) newX(m) newY(m)",
    ];
    links.forEach((l) => {
      const { lat: oy, lng: ox } = l.old.getLatLng();
      const { lat: nlat, lng: nlng } = l.new.getLatLng();
      lines.push(`${ox} ${oy} ${nlng} ${nlat}`);
    });
    downloadText("linked_points_old_pixels_new_meters.txt", lines.join("\n"));
  }

  // Expose for toolbar (single router)
  window.mapanalystExport = (what) => {
    switch (what) {
      case "old":
        return exportOldPointsTxt();
      case "new":
        return exportNewPointsTxt();
      case "linked":
        return exportLinkedPointsTxt();
      case "linked+vec":
        return exportLinkedWithVectorsInNewMapTxt();
      case "linked_px_m":
        return exportLinkedOldPixelsNewMetersTxt();
      default:
        alert("Unknown export type");
    }
  };

