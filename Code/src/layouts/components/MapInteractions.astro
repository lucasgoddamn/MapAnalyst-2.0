    const meshSize = Number.isFinite(gridSettings.meshSize)
      ? gridSettings.meshSize
      : Number(gridSettings.meshSize) || 5000;
    const meshUnit = String(gridSettings.meshUnit || "m");
    const smoothness = Number.isFinite(gridSettings.smoothness)
      ? gridSettings.smoothness
      : Number(gridSettings.smoothness) || 50;
    const extent = String(gridSettings.extent || "rectangular").toLowerCase();
    let effectiveExtent = extent;
    let polygon = null;
    if (extent === "custompolygon") {
      const rawPolygon = getPolygonCoordinates(targetMapKey);
      const normalizedPolygon = Array.isArray(rawPolygon)
        ? rawPolygon.filter(
            (pt) =>
              pt &&
              Number.isFinite(pt.lat) &&
              Number.isFinite(pt.lng)
          )
        : [];
      if (normalizedPolygon.length >= 3) {
        if (targetMapKey === "old") {
          const toNew = buildInverseGridTransform(computeResult);
          if (typeof toNew === "function") {
            const converted = normalizedPolygon
              .map((pt) => toNew(pt.lat, pt.lng))
              .filter(
                (pt) =>
                  pt &&
                  Number.isFinite(pt.lat) &&
                  Number.isFinite(pt.lng)
              );
            if (converted.length >= 3) {
              polygon = converted;
            }
          }
        } else {
          polygon = normalizedPolygon;
        }
      }
      if (!polygon) {
        effectiveExtent = "rectangular";
        if (normalizedPolygon.length >= 3) {
          console.warn(
            "Failed to transform custom polygon for distortion grid; using rectangular extent instead."
          );
        }
      }
    }

    const options = gridSettings.options || {};
    const request = {
      links,
      options: {
        mesh_size: meshSize,
        mesh_unit: meshUnit,
        extent: effectiveExtent,
        smoothness,
        show_undistorted: true,
        uncertainty_quantile: Number.isFinite(options.uncertaintyQuantile)
          ? options.uncertaintyQuantile
          : Number(options.uncertaintyQuantile) || 75,
        exaggeration: Number.isFinite(options.exaggerationFactor)
          ? options.exaggerationFactor
          : Number(options.exaggerationFactor) || 1,
        offsets: [
          Number.isFinite(options.offsetX) ? options.offsetX : Number(options.offsetX) || 0,
          Number.isFinite(options.offsetY) ? options.offsetY : Number(options.offsetY) || 0,
        ],
        polygon,
        transform_kind: String(computeResult.mode || "helmert4").toLowerCase(),
      },
    };

    const fetchKey = JSON.stringify({
      target: targetMapKey,
      request,
    });

    return {
      request,
      fetchKey,
      targetMapKey,
      otherMapKey,
      settings: gridSettings,
      showDistortedTarget,
      showUndistortedReference,
      overlayUndistortedTarget: overlayUndistorted,
      linksCount: links.length,
    };
  }

  function buildIsolineLinks(computeResult) {
    const out = [];
    if (!computeResult || !Array.isArray(computeResult.residuals)) return out;
    computeResult.residuals.forEach((res) => {
      if (!res || !res.old || !res.new) return;
      const oldCoord = {
        x: Number(res.old.x),
        y: Number(res.old.y),
      };
      const newCoord = {
        x: Number(res.new.x),
        y: Number(res.new.y),
      };
      if (
        !Number.isFinite(oldCoord.x) ||
        !Number.isFinite(oldCoord.y) ||
        !Number.isFinite(newCoord.x) ||
        !Number.isFinite(newCoord.y)
      )
        return;
      out.push({
        name: res.name || "",
        old: oldCoord,
        new: newCoord,
      });
    });
    return out;
  }

  function buildIsolineRequest(computeResult, isoSettings) {
    if (!computeResult || !isoSettings) return null;
    const targetMapKey =
      computeResult.target && String(computeResult.target).toLowerCase() === "new"
        ? "new"
        : "old";
    const showScale = !!isoSettings.scale?.show;
    const showRotation = !!isoSettings.rotation?.show;
    const radiusRaw = isoSettings.radiusOfInfluence;
    const radius = Number.isFinite(radiusRaw)
      ? Math.max(radiusRaw, 1)
      : Math.max(Number(radiusRaw) || 10000, 1);
    const links = buildIsolineLinks(computeResult);

    if (!showScale && !showRotation) {
      return {
        request: null,
        fetchKey: null,
        targetMapKey,
        showScale,
        showRotation,
        settings: isoSettings,
      };
    }

    if (links.length < 3) {
      return {
        request: null,
        fetchKey: null,
        targetMapKey,
        showScale,
        showRotation,
        settings: isoSettings,
      };
    }

    const scaleIntervalRaw = isoSettings.scale?.interval1;
    const scaleInterval = Number.isFinite(scaleIntervalRaw)
      ? Math.max(scaleIntervalRaw, 1e-6)
      : Math.max(Number(scaleIntervalRaw) || 5000, 1e-6);
    const rotIntervalRaw = isoSettings.rotation?.interval;
    const rotInterval = Number.isFinite(rotIntervalRaw)
      ? Math.max(rotIntervalRaw, 1e-6)
      : Math.max(Number(rotIntervalRaw) || 5, 1e-6);

    const request = {
      target: targetMapKey,
      links,
      options: {
        radius,
        scale: {
          show: showScale,
          interval: scaleInterval,
        },
        rotation: {
          show: showRotation,
          interval: rotInterval,
        },
      },
    };

    const fetchKey = JSON.stringify({
      target: targetMapKey,
      radius,
      scale: {
        show: showScale,
        interval: scaleInterval,
      },
      rotation: {
        show: showRotation,
        interval: rotInterval,
      },
      links: links.map((ln) => [
        ln.old.x,
        ln.old.y,
        ln.new.x,
        ln.new.y,
      ]),
    });

    return {
      request,
      fetchKey,
      targetMapKey,
      showScale,
      showRotation,
      settings: isoSettings,
    };
  }

  function normalizeParamsMap(arr) {
    const out = {};
    if (!Array.isArray(arr)) return out;
    arr.forEach((entry) => {
      if (!entry || typeof entry.name === "undefined") return;
      const key = String(entry.name).toLowerCase();
      const val = Number(entry.value);
      if (Number.isFinite(val)) out[key] = val;
    });
    return out;
  }

  function buildGridTransform(result) {
    if (!result) return null;
    const target = String(result.target || "").toLowerCase();
    if (target !== "old") return null;
    const params = normalizeParamsMap(result.parameters);
    const mode = String(result.mode || "").toLowerCase();
    const num = (value, fallback = 0) =>
      Number.isFinite(value) ? value : Number.isFinite(Number(value)) ? Number(value) : fallback;

    if (mode === "helmert4" || mode === "robust") {
      const scale = num(params.scale, 1);
      const rotation =
        num(params.rotation_deg ?? params.rotation, 0) * (Math.PI / 180);
      const cos = Math.cos(rotation);
      const sin = Math.sin(rotation);
      const tx = num(params.tx, 0);
      const ty = num(params.ty, 0);
      return (lat, lng) => {
        const x = lng;
        const y = lat;
        const Xp = scale * (cos * x - sin * y) + tx;
        const Yp = scale * (sin * x + cos * y) + ty;
        return { x: Xp, y: Yp };
      };
    }

    if (mode === "affine6") {
      const a = num(params.a, 1);
      const b = num(params.b, 0);
      const c = num(params.c, 0);
      const d = num(params.d, 1);
      const tx = num(params.tx, 0);
      const ty = num(params.ty, 0);
      return (lat, lng) => {
        const x = lng;
        const y = lat;
        const Xp = a * x + b * y + tx;
        const Yp = c * x + d * y + ty;
        return { x: Xp, y: Yp };
      };
    }

    if (mode === "affine5" || mode === "affine5_like") {
      const a = num(params.a, 1);
      const b = num(params.b, 0);
      const d = num(params.d, 1);
      const tx = num(params.tx, 0);
      const ty = num(params.ty, 0);
      return (lat, lng) => {
        const x = lng;
        const y = lat;
        const Xp = a * x + -b * y + tx;
        const Yp = b * x + d * y + ty;
        return { x: Xp, y: Yp };
      };
    }

    return null;
  }

  function buildInverseGridTransform(result) {
    if (!result) return null;
    const target = String(result.target || "").toLowerCase();
    if (target !== "old") return null;
    const params = normalizeParamsMap(result.parameters);
    const mode = String(result.mode || "").toLowerCase();
    const num = (value, fallback = 0) =>
      Number.isFinite(value) ? value : Number.isFinite(Number(value)) ? Number(value) : fallback;

    if (mode === "helmert4" || mode === "robust") {
      const scale = num(params.scale, 1);
      const tx = num(params.tx, 0);
      const ty = num(params.ty, 0);
      const rotation =
        num(params.rotation_deg ?? params.rotation, 0) * (Math.PI / 180);
      if (!Number.isFinite(scale) || Math.abs(scale) < 1e-9) return null;
      const cos = Math.cos(rotation);
      const sin = Math.sin(rotation);
      const invScale = 1 / scale;
      return (lat, lng) => {
        const Xp = lng;
        const Yp = lat;
        const dx = Xp - tx;
        const dy = Yp - ty;
        const x = invScale * (cos * dx + sin * dy);
        const y = invScale * (-sin * dx + cos * dy);
        if (!Number.isFinite(x) || !Number.isFinite(y)) return null;
        return { lat: y, lng: x };
      };
    }

    if (mode === "affine6") {
      const a = num(params.a, 1);
      const b = num(params.b, 0);
      const c = num(params.c, 0);
      const d = num(params.d, 1);
      const tx = num(params.tx, 0);
      const ty = num(params.ty, 0);
      const det = a * d - b * c;
      if (!Number.isFinite(det) || Math.abs(det) < 1e-12) return null;
      return (lat, lng) => {
        const Xp = lng;
        const Yp = lat;
        const dx = Xp - tx;
        const dy = Yp - ty;
        const x = (d * dx - b * dy) / det;
        const y = (-c * dx + a * dy) / det;
        if (!Number.isFinite(x) || !Number.isFinite(y)) return null;
        return { lat: y, lng: x };
      };
    }

    if (mode === "affine5" || mode === "affine5_like") {
      const a = num(params.a, 1);
      const b = num(params.b, 0);
      const d = num(params.d, 1);
      const tx = num(params.tx, 0);
      const ty = num(params.ty, 0);
      const det = a * d + b * b;
      if (!Number.isFinite(det) || Math.abs(det) < 1e-12) return null;
      return (lat, lng) => {
        const Xp = lng;
        const Yp = lat;
        const dx = Xp - tx;
        const dy = Yp - ty;
        const x = (d * dx + b * dy) / det;
        const y = (-b * dx + a * dy) / det;
        if (!Number.isFinite(x) || !Number.isFinite(y)) return null;
        return { lat: y, lng: x };
      };
    }

    return null;
  }

  function renderDistortionGrid(data, spec) {
    lastGridPayloadKey = spec.fetchKey || lastGridPayloadKey;
    clearDistortionLayers();
    if (!data) return;

    const showTarget = !!spec.showDistortedTarget;
    const showRef = !!spec.showUndistortedReference;
    const overlayTarget = !!spec.overlayUndistortedTarget;
    if (!showTarget && !showRef && !overlayTarget) return;

    const dgSettings = spec.settings || {};
    const baseColor = normalizeHexColor(dgSettings.color || "#444444");
    const lineWeight = parseThicknessToPixels(dgSettings.thickness || "1 pt");
    const labelSizePx = parseLabelSizeToPixels(dgSettings.labelSize || "10 pt");
    const labelFrequency = Math.max(
      1,
      Number.isFinite(dgSettings.labelFrequency)
        ? Math.round(dgSettings.labelFrequency)
        : Math.round(Number(dgSettings.labelFrequency) || 1)
    );
    const uncertaintyValue = Number.isFinite(dgSettings.uncertainty)
      ? dgSettings.uncertainty
      : Number(dgSettings.uncertainty) || 0;
    const uncertainOpacity = Math.max(
      0,
      Math.min(1, 1 - uncertaintyValue / 100)
    );
    const uncertainColor = lightenColor(baseColor, 0.35);
    const undistortedColor = lightenColor(baseColor, 0.35);
    const undistortedLabelColor = lightenColor(baseColor, 0.45);

    const labelState = { vertical: 0, horizontal: 0 };
    const shouldLabel = (orientation) => {
      const idx =
        orientation === "vertical"
          ? labelState.vertical++
          : labelState.horizontal++;
      return idx % labelFrequency === 0;
    };

    const transformToTarget =
      spec.targetMapKey === "old" ? gridTransformToOld : null;
    const transformToOther =
      spec.otherMapKey === "old" ? gridTransformToOld : null;

    const mapPoint = (pt, mapKey, transformer) => {
      if (mapKey === "old") {
        if (typeof transformer !== "function") return null;
        const projected = transformer(pt.lat, pt.lng);
        if (
          !projected ||
          !Number.isFinite(projected.x) ||
          !Number.isFinite(projected.y)
        )
          return null;
        return L.latLng(projected.y, projected.x);
      }
      return L.latLng(pt.lat, pt.lng);
    };

    if (showTarget || overlayTarget) {
      const map = getLeafletMap(spec.targetMapKey);
      if (map) {
        distortionGridGroup = L.layerGroup();
        if (showTarget && data.distorted?.length) {
          data.distorted.forEach((line) => {
            const latlngs = [];
            const anchors = [];
            line.points.forEach((pt) => {
              const mapped = mapPoint(pt, spec.targetMapKey, transformToTarget);
              if (mapped) {
                latlngs.push([mapped.lat, mapped.lng]);
                anchors.push({ mapped, original: pt });
              }
            });
            if (!latlngs.length) return;
            const isUncertain = line.points.some((pt) => pt.uncertain);
            const poly = L.polyline(latlngs, {
              color: isUncertain ? uncertainColor : baseColor,
              weight: lineWeight,
              opacity: isUncertain ? uncertainOpacity : 1,
              lineCap: "round",
              lineJoin: "round",
              interactive: false,
            }).addTo(distortionGridGroup);
            void poly;
            if (shouldLabel(line.orientation)) {
              const anchorInfo =
                anchors[Math.floor(anchors.length / 2)] || anchors[0];
              if (anchorInfo) {
                const value =
                  line.orientation === "vertical"
                    ? anchorInfo.original.lng
                    : anchorInfo.original.lat;
                const label = formatGridLabel(value, spec.targetMapKey);
                const marker = createLabelMarker(
                  anchorInfo.mapped,
                  label,
                  line.orientation,
                  labelSizePx,
                  baseColor
                );
                marker?.addTo(distortionGridGroup);
              }
            }
          });
        }

        if (overlayTarget && data.undistorted?.length) {
          const labelStateOverlay = { vertical: 0, horizontal: 0 };
          const shouldLabelOverlay = (orientation) => {
            const idx =
              orientation === "vertical"
                ? labelStateOverlay.vertical++
                : labelStateOverlay.horizontal++;
            return idx % labelFrequency === 0;
          };
          data.undistorted.forEach((line) => {
            const latlngs = [];
            const anchors = [];
            line.points.forEach((pt) => {
              const mapped = mapPoint(pt, spec.targetMapKey, transformToTarget);
              if (mapped) {
                latlngs.push([mapped.lat, mapped.lng]);
                anchors.push({ mapped, original: pt });
              }
            });
            if (!latlngs.length) return;
            const poly = L.polyline(latlngs, {
              color: undistortedColor,
              weight: Math.max(1, lineWeight * 0.8),
              opacity: 0.85,
              dashArray: "4 6",
              lineCap: "round",
              lineJoin: "round",
              interactive: false,
            }).addTo(distortionGridGroup);
            void poly;
            if (shouldLabelOverlay(line.orientation)) {
              const anchorInfo =
                anchors[Math.floor(anchors.length / 2)] || anchors[0];
              if (anchorInfo) {
                const value =
                  line.orientation === "vertical"
                    ? anchorInfo.original.lng
                    : anchorInfo.original.lat;
                const label = formatGridLabel(value, spec.targetMapKey);
                const marker = createLabelMarker(
                  anchorInfo.mapped,
                  label,
                  line.orientation,
                  labelSizePx,
                  undistortedLabelColor
                );
                marker?.addTo(distortionGridGroup);
              }
            }
          });
        }

        if (distortionGridGroup.getLayers().length > 0) {
          distortionGridGroup.addTo(map);
          distortionGridMapKey = spec.targetMapKey;
        } else {
          distortionGridGroup = null;
        }
      }
    }

    if (showRef && data.undistorted?.length) {
      const map = getLeafletMap(spec.otherMapKey);
      if (map) {
        undistortedGridGroup = L.layerGroup();
        const labelStateUnd = { vertical: 0, horizontal: 0 };
        const shouldLabelUnd = (orientation) => {
          const idx =
            orientation === "vertical"
              ? labelStateUnd.vertical++
              : labelStateUnd.horizontal++;
          return idx % labelFrequency === 0;
        };
        data.undistorted.forEach((line) => {
          const latlngs = [];
          const anchors = [];
          line.points.forEach((pt) => {
            const mapped = mapPoint(pt, spec.otherMapKey, transformToOther);
            if (mapped) {
              latlngs.push([mapped.lat, mapped.lng]);
              anchors.push({ mapped, original: pt });
            }
          });
          if (!latlngs.length) return;
          const poly = L.polyline(latlngs, {
            color: undistortedColor,
            weight: lineWeight,
            opacity: 0.9,
            dashArray: "4 6",
            lineCap: "round",
            lineJoin: "round",
            interactive: false,
          }).addTo(undistortedGridGroup);
          void poly;
          if (shouldLabelUnd(line.orientation)) {
            const anchorInfo =
              anchors[Math.floor(anchors.length / 2)] || anchors[0];
            if (anchorInfo) {
              const value =
                line.orientation === "vertical"
                  ? anchorInfo.original.lng
                  : anchorInfo.original.lat;
              const label = formatGridLabel(
                value,
                spec.otherMapKey || spec.targetMapKey
              );
              const marker = createLabelMarker(
                anchorInfo.mapped,
                label,
                line.orientation,
                labelSizePx,
                undistortedLabelColor
              );
              marker?.addTo(undistortedGridGroup);
            }
          }
        });
        undistortedGridGroup.addTo(map);
        undistortedGridMapKey = spec.otherMapKey;
      }
    }
  }

  function getDisplacementSettings() {
    const snap = ensureSettingsSnapshot();
    return snap?.displacements || null;
  }

  function clearDisplacementLayer() {
    if (displacementGroup && displacementMapKey) {
      const map = getLeafletMap(displacementMapKey);
      map?.removeLayer(displacementGroup);
    }
    displacementGroup = null;
    displacementMapKey = null;
  }

  function computeSigma(values) {
    if (!Array.isArray(values) || values.length < 2) return 0;
    const mean = values.reduce((sum, val) => sum + val, 0) / values.length;
    const variance =
      values.reduce((sum, val) => {
        const diff = val - mean;
        return sum + diff * diff;
      }, 0) / (values.length - 1);
    return Math.sqrt(Math.max(variance, 0));
  }

  function createCircleLatLngs(centerX, centerY, radius, segments = 48) {
    const pts = [];
    if (!(radius > 0)) return pts;
    for (let i = 0; i <= segments; i++) {
      const angle = (2 * Math.PI * i) / segments;
      const x = centerX + radius * Math.cos(angle);
      const y = centerY + radius * Math.sin(angle);
      pts.push([y, x]);
    }
    return pts;
  }

  function renderDisplacements(computeResult, settings) {
    clearDisplacementLayer();
    if (!computeResult || !settings || !settings.show) return;

    const target =
      computeResult.target && String(computeResult.target).toLowerCase() === "new"
        ? "new"
        : "old";
    const map = getLeafletMap(target);
    if (!map) return;

    const residuals = Array.isArray(computeResult.residuals)
      ? computeResult.residuals
      : [];
    if (!residuals.length) return;

    const mode = String(settings.mode || "vectors").toLowerCase();
    const showVectors = mode === "vectors" || mode === "both";
    const showCircles = mode === "circles" || mode === "both";
    if (!showVectors && !showCircles) return;

    const scaleFactorRaw = Number(settings.scaleFactor);
    const scaleFactor = Number.isFinite(scaleFactorRaw)
      ? Math.max(scaleFactorRaw, 0)
      : 1;
    const markOutliers = !!settings.markOutliers;
    const baseColor = normalizeHexColor(settings.color || "#000000", "#000000");
    const outlierColor = normalizeHexColor(
      settings.outlierColor || "#ff0000",
      "#ff0000"
    );
    const circleFillColor = normalizeHexColor(
      settings.circleColor || "#ffffff",
      "#ffffff"
    );
    const thickness = parseThicknessToPixels(settings.thickness || "1 pt");
    const circleAreaBoostRaw =
      Number.isFinite(settings.circleBoost) && settings.circleBoost > 0
        ? settings.circleBoost
        : DEFAULT_CIRCLE_AREA_BOOST;
    const circleAreaBoost = circleAreaBoostRaw;
    const rmse = Number(computeResult?.rmse);
    let sigma = 0;
    if (markOutliers) {
      if (Number.isFinite(rmse) && rmse > 0) {
        sigma = rmse / Math.SQRT2;
      } else {
        const lengths = residuals
          .map((res) => {
            const dx = Number(res?.vx);
            const dy = Number(res?.vy);
            if (!Number.isFinite(dx) || !Number.isFinite(dy)) return null;
            return Math.hypot(dx, dy);
          })
          .filter((val) => Number.isFinite(val));
        sigma = computeSigma(lengths);
      }
    }

    const group = L.layerGroup();
    const MIN_RADIUS = 0.0001;

    residuals.forEach((res) => {
      const dx = Number(res?.vx);
      const dy = Number(res?.vy);
      if (!Number.isFinite(dx) || !Number.isFinite(dy)) return;
      const anchor = target === "old" ? res?.old : res?.new;
      const x = Number(anchor?.x);
      const y = Number(anchor?.y);
      if (!Number.isFinite(x) || !Number.isFinite(y)) return;

      const baseLength = Math.hypot(dx, dy);
      const scaledDx = dx * scaleFactor;
      const scaledDy = dy * scaleFactor;
      const scaledLength = baseLength * scaleFactor;
      const circleAreaLength = scaledLength * circleAreaBoost;
      const strokeColor =
        markOutliers && sigma > 0 && baseLength > 3 * sigma
          ? outlierColor
          : baseColor;

      if (showVectors) {
        const start = L.latLng(y, x);
        const end = L.latLng(y + scaledDy, x + scaledDx);
        L.polyline([start, end], {
          color: strokeColor,
          weight: thickness,
          opacity: 1,
          lineCap: "round",
          interactive: false,
        }).addTo(group);
      }

      if (showCircles && circleAreaLength > 0) {
        const radius = Math.sqrt(Math.max(circleAreaLength, 0) / Math.PI);
        const renderRadius = Math.max(radius, MIN_RADIUS);
        const circlePts = createCircleLatLngs(x, y, renderRadius);
        if (circlePts.length) {
          L.polygon(circlePts, {
            color: strokeColor,
            weight: thickness,
            fill: true,
            fillOpacity: settings.fullCircles ? 0.6 : 0,
            fillColor: settings.fullCircles ? circleFillColor : strokeColor,
            interactive: false,
          }).addTo(group);
        }

        const crossHoriz = [
          [y, x - renderRadius],
          [y, x + renderRadius],
        ];
        const crossVert = [
          [y - renderRadius, x],
          [y + renderRadius, x],
        ];
        L.polyline(crossHoriz, {
          color: strokeColor,
          weight: thickness * 0.75,
          opacity: 1,
          interactive: false,
        }).addTo(group);
        L.polyline(crossVert, {
          color: strokeColor,
          weight: thickness * 0.75,
          opacity: 1,
          interactive: false,
        }).addTo(group);
      }
    });

    if (group.getLayers().length) {
      group.addTo(map);
      displacementGroup = group;
      displacementMapKey = target;
    }
  }

  function refreshDisplacements() {
    const settings = getDisplacementSettings();
    if (!settings || !settings.show || !lastComputeResult) {
      clearDisplacementLayer();
      return;
    }
    renderDisplacements(lastComputeResult, settings);
  }

  function clearIsolineLayers() {
    if (isolineScaleGroup && isolineMapKey) {
      const map = getLeafletMap(isolineMapKey);
      map?.removeLayer(isolineScaleGroup);
    }
    if (isolineRotationGroup && isolineMapKey) {
      const map = getLeafletMap(isolineMapKey);
      map?.removeLayer(isolineRotationGroup);
    }
    isolineScaleGroup = null;
    isolineRotationGroup = null;
    isolineMapKey = null;
  }

  function renderIsolines(data, spec) {
    clearIsolineLayers();
    if (!data || (!spec.showScale && !spec.showRotation)) return;
    const map = getLeafletMap(spec.targetMapKey);
    if (!map) return;

    const scaleColor = normalizeHexColor(
      spec.settings?.scale?.color1 || "#222222",
      "#222222"
    );
    const scaleWeight = parseThicknessToPixels(
      spec.settings?.scale?.thickness1 || "1 pt"
    );
    const rotationColor = normalizeHexColor(
      spec.settings?.rotation?.color || "#222222",
      "#222222"
    );
    const rotationWeight = parseThicknessToPixels(
      spec.settings?.rotation?.thickness || "1 pt"
    );

    let added = false;

    if (spec.showScale && Array.isArray(data.scale?.levels)) {
      const scaleGroup = L.layerGroup();
      data.scale.levels.forEach((lvl) => {
        if (!lvl || !Array.isArray(lvl.lines)) return;
        lvl.lines.forEach((line) => {
          if (!Array.isArray(line) || line.length < 2) return;
          const latlngs = line.map((pt) => [pt.lat, pt.lng]);
          L.polyline(latlngs, {
            color: scaleColor,
            weight: scaleWeight,
            opacity: 0.95,
            dashArray: null,
            interactive: false,
          }).addTo(scaleGroup);
        });
      });
      if (scaleGroup.getLayers().length) {
        scaleGroup.addTo(map);
        isolineScaleGroup = scaleGroup;
        added = true;
      }
    }

    if (spec.showRotation && Array.isArray(data.rotation?.levels)) {
      const rotationGroup = L.layerGroup();
      data.rotation.levels.forEach((lvl) => {
        if (!lvl || !Array.isArray(lvl.lines)) return;
        lvl.lines.forEach((line) => {
          if (!Array.isArray(line) || line.length < 2) return;
          const latlngs = line.map((pt) => [pt.lat, pt.lng]);
          L.polyline(latlngs, {
            color: rotationColor,
            weight: rotationWeight,
            opacity: 0.85,
            dashArray: "8 6",
            interactive: false,
          }).addTo(rotationGroup);
        });
      });
      if (rotationGroup.getLayers().length) {
        rotationGroup.addTo(map);
        isolineRotationGroup = rotationGroup;
        added = true;
      }
    }

    if (added) {
      isolineMapKey = spec.targetMapKey;
    }
  }

  async function refreshIsolines({ forceFetch = false } = {}) {
    const computeResult = lastComputeResult;
    const isoSettings = getIsolineSettings();
    if (!computeResult || !isoSettings) {
      clearIsolineLayers();
      isolineData = null;
      lastIsolinePayloadKey = null;
      return;
    }

    const spec = buildIsolineRequest(computeResult, isoSettings);
    if (!spec || !spec.request) {
      clearIsolineLayers();
      isolineData = null;
      lastIsolinePayloadKey = null;
      return;
    }

    clearIsolineLayers();

    if (
      !forceFetch &&
      isolineData &&
      spec.fetchKey &&
      spec.fetchKey === lastIsolinePayloadKey
    ) {
      renderIsolines(isolineData, spec);
      return;
    }

    lastIsolinePayloadKey = spec.fetchKey || null;
    isolineFetchController?.abort();
    const controller = new AbortController();
    isolineFetchController = controller;

    try {
      const res = await fetch("http://localhost:8000/api/visual/isolines", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(spec.request),
        signal: controller.signal,
      });
      if (!res.ok) {
        const errText = await res.text();
        throw new Error(errText || `Isolines failed (${res.status})`);
      }
      const data = await res.json();
      isolineData = data;
      renderIsolines(isolineData, spec);
    } catch (err) {
      if (controller.signal.aborted) return;
      console.error("Isolines error", err);
      alert(
        err?.message ? `Isolines error: ${err.message}` : "Failed to compute isolines."
      );
      isolineData = null;
      lastIsolinePayloadKey = null;
      clearIsolineLayers();
    } finally {
      if (isolineFetchController === controller) {
        isolineFetchController = null;
      }
    }
  }

  async function refreshDistortionGrid({ forceFetch = false } = {}) {
    const computeResult = lastComputeResult;
    const gridSettings = getDistortionGridSettings();
    if (!computeResult || !gridSettings) {
      clearDistortionLayers();
      distortionGridData = null;
      return;
    }

    const spec = buildGridRequest(computeResult, gridSettings);
    if (!spec) {
      clearDistortionLayers();
      distortionGridData = null;
      return;
    }

    if (
      !spec.showDistortedTarget &&
      !spec.showUndistortedReference &&
      !spec.overlayUndistortedTarget
    ) {
      clearDistortionLayers();
      return;
    }

    if (!spec.request || spec.linksCount < 3) {
      clearDistortionLayers();
      distortionGridData = null;
      return;
    }

    const needFetch =
      forceFetch ||
      !distortionGridData ||
      spec.fetchKey !== lastGridPayloadKey ||
      ((spec.showUndistortedReference || spec.overlayUndistortedTarget) &&
        !distortionGridData?.undistorted);

    if (!needFetch) {
      renderDistortionGrid(distortionGridData, spec);
      return;
    }

    lastGridPayloadKey = spec.fetchKey;
    gridFetchController?.abort();
    const controller = new AbortController();
    gridFetchController = controller;

    try {
      const res = await fetch("http://localhost:8000/api/visual/distortion-grid", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(spec.request),
        signal: controller.signal,
      });
      if (!res.ok) {
        const errText = await res.text();
        throw new Error(errText || `Distortion grid failed (${res.status})`);
      }
      const data = await res.json();
      distortionGridData = data;
      renderDistortionGrid(distortionGridData, spec);
    } catch (err) {
      if (controller.signal.aborted) return;
      console.error("Distortion grid error", err);
      alert(
        err?.message
          ? `Distortion grid error: ${err.message}`
          : "Failed to compute distortion grid."
      );
      distortionGridData = null;
      lastGridPayloadKey = null;
      clearDistortionLayers();
    } finally {
      if (gridFetchController === controller) {
        gridFetchController = null;
      }
    }
  }

  function setTargetMap(mapKey, opts = {}) {
    const normalized = mapKey === "new" ? "new" : "old";
    const previous = currentTargetMap;
    currentTargetMap = normalized;
    const otherKey = normalized === "old" ? "new" : "old";
    if (opts.syncSelection !== false) {
      const targetState = getPolygonState(normalized);
      const otherState = getPolygonState(otherKey);
      if (otherState) otherState.selected = false;
      if (
        targetState &&
        targetState.isClosed &&
        targetState.coords.length >= 3
      ) {
        targetState.selected = true;
      }
      updatePolygonStyle("old");
      updatePolygonStyle("new");
    }
    applyExtentVisibility();
    if (previous !== normalized && !opts.skipHistory) pushHistory();
  }

  function deleteSelectedPolygon(options = {}) {
    const key = getSelectedPolygonKey();
    if (!key) return false;
    const skipHistory = options.skipHistory ?? false;
    clearPolygon(key, skipHistory);
    applyExtentVisibility();
    return true;
  }

  function refreshPolygonModeHelpers() {
    if (mode !== "polygon") {
      ["old", "new"].forEach((key) => {
        const state = getPolygonState(key);
        if (!state) return;
        if (state.drawing && state.hoverLatLng) {
          state.hoverLatLng = null;
          syncPolygonLayers(key);
        }
      });
    }
    const shouldDisable = mode === "polygon";
    [oldMapInstance, newMapInstance].forEach((map) => {
      if (!map || !map.doubleClickZoom) return;
      if (shouldDisable) map.doubleClickZoom.disable();
      else map.doubleClickZoom.enable();
    });
  }

  function getCurrentExtent() {
    if (lastSettingsSnapshot?.distortionGrid?.extent) return lastSettingsSnapshot.distortionGrid.extent;
    const extentSelect = document.getElementById("dg-extent");
    return extentSelect ? String(extentSelect.value || "rectangular") : "rectangular";
  }

  function applyExtentVisibility() {
    const rawExtent = getCurrentExtent() || "rectangular";
    const extent = rawExtent.toLowerCase();
    if (extent === "custompolygon") {
      const target = currentTargetMap === "new" ? "new" : "old";
      const targetState = getPolygonState(target);
      const hasValidPolygon =
        targetState && targetState.isClosed && targetState.coords.length >= 3;
      const isSelected = !!(targetState && targetState.selected && hasValidPolygon);

      if (!hasValidPolygon || !isSelected) {
        ["old", "new"].forEach((key) => {
          const state = getPolygonState(key);
          if (!state) return;
          state.hidden = false;
          syncPolygonLayers(key);
        });

        if (!extentWarningShown) {
          alert(
            "Please first draw a polygon in the map with the distorted grid using the pen tool. The polygon must be selected. Only one polygon can be used as mask."
          );
          extentWarningShown = true;
        }

        const select = document.getElementById("dg-extent");
        if (select) {
          select.value = lastValidExtentValue;
          select.dispatchEvent(new Event("change", { bubbles: true }));
        }
        if (lastSettingsSnapshot?.distortionGrid) {
          lastSettingsSnapshot.distortionGrid.extent = lastValidExtentValue;
        }
        return;
      }

      extentWarningShown = false;
      lastValidExtentValue = "customPolygon";
      ["old", "new"].forEach((key) => {
        const state = getPolygonState(key);
        if (!state) return;
        state.hidden = key === target;
        syncPolygonLayers(key);
      });
    } else {
      extentWarningShown = false;
      lastValidExtentValue = rawExtent || "rectangular";
      ["old", "new"].forEach((key) => {
        const state = getPolygonState(key);
        if (!state) return;
        state.hidden = false;
        syncPolygonLayers(key);
      });
    }
  }

  function applyAppearanceChange(target, { size, opacity }) {
    const targets =
      target === "both" ? ["old", "new"] : target === "old" || target === "new" ? [target] : ["old", "new"];
    targets.forEach((key) => {
      if (typeof size === "number") markerAppearance[key].size = size;
      if (typeof opacity === "number") markerAppearance[key].opacity = opacity;
      applyMarkerAppearance(key);
    });
  }

  function getCombinedAppearance(target) {
    const keys =
      target === "both"
        ? ["old", "new"]
        : target === "old" || target === "new"
        ? [target]
        : ["old", "new"];
    const avgSize =
      keys.reduce((sum, key) => sum + markerAppearance[key].size, 0) /
      keys.length;
    const avgOpacity =
      keys.reduce((sum, key) => sum + markerAppearance[key].opacity, 0) /
      keys.length;
    return { size: avgSize, opacity: avgOpacity };
  }

  function setupPointsVisibilityControls() {
    const btn = document.getElementById("btn-points-visibility");
    const popover = document.getElementById("points-visibility-popover");
    const sizeSlider = document.getElementById("pv-size");
    const opacitySlider = document.getElementById("pv-opacity");
    const sizeValue = document.getElementById("pv-size-value");
    const opacityValue = document.getElementById("pv-opacity-value");
    const targetRadios = [
      document.getElementById("pv-target-old"),
      document.getElementById("pv-target-new"),
      document.getElementById("pv-target-both"),
    ].filter(Boolean);
    const resetBtn = document.getElementById("pv-reset");
    if (!btn || !popover || !sizeSlider || !opacitySlider) return;

    const updateSliderLabels = () => {
      const info = getCombinedAppearance(markerAppearanceTarget);
      const sizePercent = Math.round(info.size * 100);
      const opacityPercent = Math.round(info.opacity * 100);
      sizeSlider.value = sizePercent.toString();
      opacitySlider.value = opacityPercent.toString();
      if (sizeValue) sizeValue.textContent = `${sizePercent}%`;
      if (opacityValue) opacityValue.textContent = `${opacityPercent}%`;
    };

    const closePopover = () => {
      popover.classList.add("hidden");
      btn.classList.remove("bg-gray-200", "dark:bg-gray-700");
      document.removeEventListener("mousedown", outsideClickHandler);
      document.removeEventListener("keydown", escapeHandler);
    };

    const openPopover = () => {
      updateSliderLabels();
      popover.classList.remove("hidden");
      btn.classList.add("bg-gray-200", "dark:bg-gray-700");
      document.addEventListener("mousedown", outsideClickHandler);
      document.addEventListener("keydown", escapeHandler);
    };

    const outsideClickHandler = (ev) => {
      if (!popover.contains(ev.target) && ev.target !== btn) {
        closePopover();
      }
    };

    const escapeHandler = (ev) => {
      if (ev.key === "Escape") closePopover();
    };

    btn.addEventListener("click", () => {
      if (popover.classList.contains("hidden")) openPopover();
      else closePopover();
    });

    targetRadios.forEach((radio) => {
      radio.addEventListener("change", () => {
        if (!radio.checked) return;
        markerAppearanceTarget = radio.value || "both";
        updateSliderLabels();
      });
    });

    sizeSlider.addEventListener("input", () => {
      const value = Math.max(0, Number(sizeSlider.value) / 100);
      if (sizeValue) sizeValue.textContent = `${Math.round(value * 100)}%`;
      applyAppearanceChange(markerAppearanceTarget, { size: value });
    });

    opacitySlider.addEventListener("input", () => {
      const value = Number(opacitySlider.value) / 100;
      if (opacityValue) opacityValue.textContent = `${Math.round(value * 100)}%`;
      applyAppearanceChange(markerAppearanceTarget, { opacity: value });
    });

    resetBtn?.addEventListener("click", (ev) => {
      ev.preventDefault();
      markerAppearance.old = { size: 1, opacity: 1 };
      markerAppearance.new = { size: 1, opacity: 1 };
      applyMarkerAppearance("old");
      applyMarkerAppearance("new");
      updateSliderLabels();
    });
  }

  // ---------- UNDO / REDO ----------
  let history = [];
  let historyPointer = -1;

  function pushHistory() {
    const state = {
      oldMarkers: oldMarkers.map((m) => ({ latlng: m.getLatLng() })),
      newMarkers: newMarkers.map((m) => ({ latlng: m.getLatLng() })),
      links: links.map((l) => ({
        old: oldMarkers.indexOf(l.old),
        new: newMarkers.indexOf(l.new),
        name: l.name,
      })),
      selected: [...selectedMarkers].map((m) =>
        oldMarkers.includes(m)
          ? { map: "old", idx: oldMarkers.indexOf(m) }
          : { map: "new", idx: newMarkers.indexOf(m) }
      ),
      polygons: {
        old: serializePolygonState("old"),
        new: serializePolygonState("new"),
      },
      polygonTarget: currentTargetMap,
    };
    history = history.slice(0, historyPointer + 1);
    history.push(state);
    historyPointer = history.length - 1;
  }

  
function restoreHistory(idx) {
    if (idx < 0 || idx >= history.length) return;
    // wipe
    oldMarkers.forEach((m) => m.remove());
    newMarkers.forEach((m) => m.remove());
    oldMarkers.length = 0;
    newMarkers.length = 0;
    links.length = 0;
    selectedMarkers.clear();

    const snap = history[idx];
    snap.oldMarkers.forEach((o) => {
      const m = L.marker(o.latlng, {
        icon: new RedIcon(),
        draggable: false,
      }).addTo(oldMapInstance);
      hookMarker(m, oldMarkers, true);
      oldMarkers.push(m);
    });
    snap.newMarkers.forEach((o) => {
      const m = L.marker(o.latlng, {
        icon: new RedIcon(),
        draggable: false,
      }).addTo(newMapInstance);
      hookMarker(m, newMarkers, false);
      newMarkers.push(m);
    });
    snap.links.forEach((l) => {
      if (l.old >= 0 && l.new >= 0)
        links.push({
          old: oldMarkers[l.old],
          new: newMarkers[l.new],
          name: l.name,
        });
    });
    snap.selected.forEach((s) => {
      if (s.map === "old" && oldMarkers[s.idx])
        selectedMarkers.add(oldMarkers[s.idx]);
      if (s.map === "new" && newMarkers[s.idx])
        selectedMarkers.add(newMarkers[s.idx]);
    });

    if (snap.polygons) {
      loadPolygonState("old", snap.polygons.old);
      loadPolygonState("new", snap.polygons.new);
    } else {
      loadPolygonState("old", null);
      loadPolygonState("new", null);
    }
    currentTargetMap = snap.polygonTarget === "new" ? "new" : "old";
    updatePolygonStyle("old");
    updatePolygonStyle("new");
    applyExtentVisibility();

    updateMarkerStyles();
  }

  window.addEventListener("mapanalyst:undo", () => {
    if (historyPointer > 0) {
      restoreHistory(historyPointer - 1);
      historyPointer--;
    }
  });
  window.addEventListener("mapanalyst:redo", () => {
    if (historyPointer < history.length - 1) {
      restoreHistory(historyPointer + 1);
      historyPointer++;
    }
  });

  window.addEventListener("mapanalyst:settings-changed", (ev) => {
    lastSettingsSnapshot = ev.detail || null;
    applyExtentVisibility();
    refreshDistortionGrid().catch((err) =>
      console.error("Failed to refresh distortion grid:", err)
    );
    refreshIsolines().catch((err) =>
      console.error("Failed to refresh isolines:", err)
    );
    try {
      refreshDisplacements();
    } catch (err) {
      console.error("Failed to refresh displacements:", err);
    }
  });

  window.addEventListener("mapanalyst:show-all", () => {
    if (oldMapInstance) {
      if (oldMapDefaultBounds?.isValid?.()) {
        oldMapInstance.fitBounds(oldMapDefaultBounds);
      } else {
        const center = oldMapInstance.getCenter?.();
        if (center) oldMapInstance.setView(center, oldMapInstance.getZoom());
      }
    }
    if (newMapInstance) {
      if (newMapDefaultBounds?.isValid?.()) {
        newMapInstance.fitBounds(newMapDefaultBounds);
      } else if (newMapDefaultView?.center) {
        newMapInstance.setView(
          newMapDefaultView.center,
          Number.isFinite(newMapDefaultView.zoom)
            ? newMapDefaultView.zoom
            : newMapInstance.getZoom()
        );
      }
    }
  });

  window.addEventListener("mapanalyst:target-map", (ev) => {
    const detail = ev.detail || {};
    const rawTarget =
      detail.target || detail.map || detail.value || detail.name || "old";
    const normalized =
      typeof rawTarget === "string" ? rawTarget.toLowerCase() : "old";
    const skipHistory = historyPointer < 0;
    setTargetMap(normalized, { skipHistory });
    refreshDistortionGrid().catch((err) =>
      console.error("Failed to refresh distortion grid:", err)
    );
    refreshIsolines().catch((err) =>
      console.error("Failed to refresh isolines:", err)
    );
    try {
      refreshDisplacements();
    } catch (err) {
      console.error("Failed to refresh displacements:", err);
    }
  });

  window.addEventListener("mapanalyst:result", (ev) => {
    const detail = ev.detail || null;
    if (!detail) return;
    lastComputeResult = detail;
    gridTransformToOld = buildGridTransform(detail);
    const normalized =
      detail.target && String(detail.target).toLowerCase() === "new"
        ? "new"
        : "old";
    setTargetMap(normalized, { skipHistory: true, syncSelection: false });
    refreshDistortionGrid({ forceFetch: true }).catch((err) =>
      console.error("Failed to fetch distortion grid:", err)
    );
    refreshIsolines({ forceFetch: true }).catch((err) =>
      console.error("Failed to fetch isolines:", err)
    );
    try {
      refreshDisplacements();
    } catch (err) {
      console.error("Failed to render displacements:", err);
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Delete") return;
    const target = e.target;
    const tag = target && target.tagName ? target.tagName.toUpperCase() : "";
    if (tag && (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT")) return;
    if (target && target.isContentEditable) return;
    if (selectedMarkers.size === 0 && !getSelectedPolygonKey()) return;
    e.preventDefault();
    setMode("delete");
  });

  // ---------- MEASURE ----------
  let isMeasuringOld = false,
    isMeasuringNew = false;
  let measureStartLatLngOld = null,
    measureLineOld = null;
  let measureStartLatLngNew = null,
    measureLineNew = null;

  // ---------- UI HELPERS ----------
  function updateMarkerStyles() {
    [...oldMarkers, ...newMarkers].forEach((m) => {
      const isLinked = links.some((ln) => ln.old === m || ln.new === m);
      if (isLinked) {
        m.setIcon(new GreenIcon());
        if (m._icon)
          m._icon.style.filter =
            "hue-rotate(90deg) saturate(2) brightness(1.5)";
      } else if (selectedMarkers.has(m)) {
        m.setIcon(new RedIcon());
        if (m._icon)
          m._icon.style.filter =
            "hue-rotate(145deg) saturate(3.5) brightness(1)";
      } else {
        m.setIcon(new DefaultIconClass());
        if (m._icon) m._icon.style.filter = "";
      }

      applyMarkerAppearanceToMarker(
        m,
        oldMarkers.includes(m) ? "old" : "new"
      );
    });
    updateSelectionDisplay();
  }

  function updateSelectionDisplay() {
    const oldSel = [...selectedMarkers].filter((m) => oldMarkers.includes(m));
    const newSel = [...selectedMarkers].filter((m) => newMarkers.includes(m));
    if (oldSel.length === 1) {
      const { lat, lng } = oldSel[0].getLatLng();
      setText("sel-old-x", lng.toFixed(2));
      setText("sel-old-y", lat.toFixed(2));
    } else {
      setText("sel-old-x", "");
      setText("sel-old-y", "");
    }
    if (newSel.length === 1) {
      const { lat, lng } = newSel[0].getLatLng();
      setText("sel-new-x", lng.toFixed(5));
      setText("sel-new-y", lat.toFixed(5));
    } else {
      setText("sel-new-x", "");
      setText("sel-new-y", "");
    }

    const linkBtn = qs("#btn-link");
    const renameBtn = qs("#btn-rename");
    if (oldSel.length === 1 && newSel.length === 1) {
      linkBtn?.removeAttribute("disabled");
      linkBtn?.classList.replace("bg-gray-200", "bg-blue-500");
    } else {
      linkBtn?.setAttribute("disabled", "");
      linkBtn?.classList.replace("bg-blue-500", "bg-gray-200");
    }
    const existing = links.find(
      (ln) => ln.old === oldSel[0] && ln.new === newSel[0]
    );
    const nameSpan = qs("#selected-link-name");
    if (existing) {
      if (nameSpan) nameSpan.textContent = existing.name;
      renameBtn?.removeAttribute("disabled");
      renameBtn?.classList.replace("bg-gray-200", "bg-blue-500");
    } else {
      if (nameSpan) nameSpan.textContent = "-";
      renameBtn?.setAttribute("disabled", "");
      renameBtn?.classList.replace("bg-blue-500", "bg-gray-200");
    }
  }

  function setText(id, v) {
    const el = document.getElementById(id);
    if (el) el.textContent = v;
  }
  function qs(sel) {
    return document.querySelector(sel);
  }

  function setMode(newMode) {
    if (newMode !== "measure") {
      clearOldMeasure();
      clearNewMeasure();
    }

    if (newMode === "delete" && selectedMarkers.size > 0) {
      // Delete selected markers, unlink if needed, and select counterpart
      selectedMarkers.forEach((m) => {
        // If marker participates in a link, remove link and select counterpart
        for (let i = links.length - 1; i >= 0; i--) {
          const ln = links[i];
          if (ln.old === m || ln.new === m) {
            const counterpart = ln.old === m ? ln.new : ln.old;
            links.splice(i, 1);
            if (counterpart && counterpart._map) {
              selectedMarkers.add(counterpart);
            }
          }
        }
        // remove marker itself
        m._map.removeLayer(m);
        removeFromBucket(m, oldMarkers);
        removeFromBucket(m, newMarkers);
      });
      selectedMarkers.forEach((m) => {
        /* keep selection only for still present counterparts */ if (!m._map)
          selectedMarkers.delete(m);
      });
      updateMarkerStyles();
      pushHistory();
      emitLinkStateChanged();
      clearSuggestions("data-changed");
      refreshPolygonModeHelpers();
      return;
    }

    if (newMode === "delete" && selectedMarkers.size === 0) {
      if (deleteSelectedPolygon()) {
        refreshPolygonModeHelpers();
        return;
      }
    }

    mode = mode === newMode ? null : newMode;
    document.querySelectorAll("[data-mode]").forEach((btn) => {
      btn.classList.toggle("bg-blue-200", btn.dataset.mode === mode);
    });
    [...oldMarkers, ...newMarkers].forEach((m) => {
      if (mode === "move" && selectedMarkers.has(m)) m.dragging.enable();
      else m.dragging.disable();
    });
    refreshPolygonModeHelpers();
  }

  function removeFromBucket(m, bucket) {
    const i = bucket.indexOf(m);
    if (i > -1) bucket.splice(i, 1);
  }

  function hookMarker(marker, bucket, isOld) {
    const mapKey = isOld ? "old" : "new";
    const reapplyAppearance = () => applyMarkerAppearanceToMarker(marker, mapKey);
    marker.on("add", reapplyAppearance);
    if (marker._icon) reapplyAppearance();
    marker.on("click", () => {
      if (mode === "delete" && selectedMarkers.size === 0) {
        // delete single marker with auto-unlink/select counterpart
        for (let i = links.length - 1; i >= 0; i--) {
          const ln = links[i];
          if (ln.old === marker || ln.new === marker) {
            const counterpart = ln.old === marker ? ln.new : ln.old;
            links.splice(i, 1);
            if (counterpart && counterpart._map) {
              selectedMarkers.add(counterpart);
            }
          }
        }
        marker._map.removeLayer(marker);
        removeFromBucket(marker, bucket);
        updateMarkerStyles();
        pushHistory();
      } else {
        if (selectedMarkers.has(marker)) selectedMarkers.delete(marker);
        else selectedMarkers.add(marker);
        updateMarkerStyles();
        pushHistory();
      }
    });
    marker.on("dragend", () => {
      selectedMarkers.clear();
      selectedMarkers.add(marker);
      updateMarkerStyles();
      pushHistory();
    });
    marker.dragging.disable();
  }

  function addPoint(map, latlng, bucket) {
    bucket.forEach((m) => selectedMarkers.delete(m)); // selecting one new in that bucket
    const marker = L.marker(latlng, {
      icon: new RedIcon(),
      draggable: false,
    }).addTo(map);
    hookMarker(marker, bucket, bucket === oldMarkers);
    selectedMarkers.add(marker);
    clearSuggestions("data-changed");
    setTimeout(() => {
      updateMarkerStyles();
      pushHistory();
    }, 0);
    bucket.push(marker);
  }

  // ---------- MEASURE HELPERS ----------
  function clearOldMeasure() {
    if (measureLineOld) oldMapInstance.removeLayer(measureLineOld);
    measureLineOld = null;
    setOldMapMeasureResult("-", "-");
    isMeasuringOld = false;
    measureStartLatLngOld = null;
    oldMapInstance?.dragging.enable();
  }
  function clearNewMeasure() {
    if (measureLineNew) newMapInstance.removeLayer(measureLineNew);
    measureLineNew = null;
    setNewMapMeasureResult("-", "-");
    isMeasuringNew = false;
    measureStartLatLngNew = null;
    newMapInstance?.dragging.enable();
  }

  function getBearing(a, b) {
    const toRad = (d) => (d * Math.PI) / 180,
      toDeg = (r) => (r * 180) / Math.PI;
    const lat1 = toRad(a[0]),
      lat2 = toRad(b[0]);
    const dLon = toRad(b[1] - a[1]);
    const y = Math.sin(dLon) * Math.cos(lat2);
    const x =
      Math.cos(lat1) * Math.sin(lat2) -
      Math.sin(lat1) * Math.cos(lat2) * Math.cos(dLon);
    let brng = toDeg(Math.atan2(y, x));
    return (brng + 360) % 360;
  }
  function setOldMapMeasureResult(dist, angle) {
    setText("oldMapDistance", dist);
    setText("oldMapAngle", angle);
  }
  function setNewMapMeasureResult(dist, angle) {
    setText("newMapDistance", dist);
    setText("newMapAngle", angle);
  }

  // ---------- MAP WIRING ----------
  function attachTools(map, bucket, isOld) {
    const mapKey = isOld ? "old" : "new";
    map.on("mousemove", (e) => {
      setText(
        isOld ? "oldMapX" : "newMapX",
        isOld ? e.latlng.lng.toFixed(0) : e.latlng.lng.toFixed(5)
      );
      setText(
        isOld ? "oldMapY" : "newMapY",
        isOld ? e.latlng.lat.toFixed(0) : e.latlng.lat.toFixed(5)
      );

      if (mode === "measure") {
        if (isOld && isMeasuringOld && measureStartLatLngOld) {
          if (measureLineOld) oldMapInstance.removeLayer(measureLineOld);
          measureLineOld = L.polyline([measureStartLatLngOld, e.latlng], {
            color: "brown",
            weight: 3,
            dashArray: "6 3",
          }).addTo(oldMapInstance);
          const dx = e.latlng.lng - measureStartLatLngOld.lng,
            dy = e.latlng.lat - measureStartLatLngOld.lat;
          const dist = Math.sqrt(dx * dx + dy * dy);
          let angle = (Math.atan2(dy, dx) * 180) / Math.PI;
          if (angle < 0) angle += 360;
          setOldMapMeasureResult(
            dist.toFixed(1) + " px",
            angle.toFixed(1) + "°"
          );
        } else if (!isOld && isMeasuringNew && measureStartLatLngNew) {
          if (measureLineNew) newMapInstance.removeLayer(measureLineNew);
          measureLineNew = L.polyline([measureStartLatLngNew, e.latlng], {
            color: "brown",
            weight: 3,
            dashArray: "6 3",
          }).addTo(newMapInstance);
          const dist =
            newMapInstance.distance(
              [measureStartLatLngNew.lat, measureStartLatLngNew.lng],
              [e.latlng.lat, e.latlng.lng]
            ) / 1000.0;
          const bearing = getBearing(
            [measureStartLatLngNew.lat, measureStartLatLngNew.lng],
            [e.latlng.lat, e.latlng.lng]
          );
          setNewMapMeasureResult(
            dist.toFixed(2) + " km",
            bearing.toFixed(1) + "°"
          );
        } else if (isOld) setOldMapMeasureResult("-", "-");
        else setNewMapMeasureResult("-", "-");
      }

      if (mode === "polygon") updatePolygonPreview(mapKey, e.latlng);
      else updatePolygonPreview(mapKey, null);

    });

    map.on("mousedown", (e) => {
      if (mode === "select") {
        let box,
          start = e.latlng;
        box = L.rectangle([start, start], {
          color: "blue",
          dashArray: "4",
        }).addTo(map);
        map.dragging.disable();
        const updateBox = (ev) =>
          box.setBounds(L.latLngBounds(start, ev.latlng));
        const finishSelect = () => {
          const bounds = box.getBounds();
          bucket.forEach((m) => selectedMarkers.delete(m));
          bucket.forEach((m) => {
            if (bounds.contains(m.getLatLng())) selectedMarkers.add(m);
          });
          updateMarkerStyles();
          pushHistory();
          map.removeLayer(box);
          map.dragging.enable();
          map.off("mousemove", updateBox);
        };
        map.on("mousemove", updateBox);
        map.once("mouseup", finishSelect);
      }

      if (mode === "measure") {
        if (isOld) {
          isMeasuringOld = true;
          measureStartLatLngOld = e.latlng;
          if (measureLineOld) {
            oldMapInstance.removeLayer(measureLineOld);
            measureLineOld = null;
          }
          oldMapInstance.dragging.disable();
        } else {
          isMeasuringNew = true;
          measureStartLatLngNew = e.latlng;
          if (measureLineNew) {
            newMapInstance.removeLayer(measureLineNew);
            measureLineNew = null;
          }
          newMapInstance.dragging.disable();
        }
      }
    });

    map.on("mouseup", (e) => {
      if (mode === "measure") {
        if (isOld && isMeasuringOld && measureStartLatLngOld) {
          if (measureLineOld) oldMapInstance.removeLayer(measureLineOld);
          measureLineOld = L.polyline([measureStartLatLngOld, e.latlng], {
            color: "brown",
            weight: 3,
          }).addTo(oldMapInstance);
          const dx = e.latlng.lng - measureStartLatLngOld.lng,
            dy = e.latlng.lat - measureStartLatLngOld.lat;
          const dist = Math.sqrt(dx * dx + dy * dy);
          let angle = (Math.atan2(dy, dx) * 180) / Math.PI;
          if (angle < 0) angle += 360;
          setOldMapMeasureResult(
            dist.toFixed(1) + " px",
            angle.toFixed(1) + "°"
          );
          isMeasuringOld = false;
          measureStartLatLngOld = null;
          oldMapInstance.dragging.enable();
        }
        if (!isOld && isMeasuringNew && measureStartLatLngNew) {
          if (measureLineNew) newMapInstance.removeLayer(measureLineNew);
          measureLineNew = L.polyline([measureStartLatLngNew, e.latlng], {
            color: "brown",
            weight: 3,
          }).addTo(newMapInstance);
          const dist =
            newMapInstance.distance(
              [measureStartLatLngNew.lat, measureStartLatLngNew.lng],
              [e.latlng.lat, e.latlng.lng]
            ) / 1000.0;
          const bearing = getBearing(
            [measureStartLatLngNew.lat, measureStartLatLngNew.lng],
            [e.latlng.lat, e.latlng.lng]
          );
          setNewMapMeasureResult(
            dist.toFixed(2) + " km",
            bearing.toFixed(1) + "°"
          );
          isMeasuringNew = false;
          measureStartLatLngNew = null;
          newMapInstance.dragging.enable();
        }
      }
    });

    map.on("dblclick", (e) => {
      if (mode === "polygon") {
        finalizePolygon(mapKey);
        e.originalEvent?.preventDefault?.();
        e.originalEvent?.stopPropagation?.();
      }
    });

    map.on("click", (e) => {
      if (mode === "polygon") {
        handlePolygonVertex(mapKey, e.latlng);
        return;
      }
      if (mode === "new") addPoint(map, e.latlng, bucket);
    });
    bucket.forEach((m) => m.dragging.disable());
  }

