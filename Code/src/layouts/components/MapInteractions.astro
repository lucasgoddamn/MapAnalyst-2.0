  function styleMarkerIcon(marker, config) {
    if (!marker) return;
    const icon = marker._icon;
    if (icon) {
      const width = BASE_ICON_SIZE[0] * config.size;
      const height = BASE_ICON_SIZE[1] * config.size;
      const anchorX = (BASE_ICON_ANCHOR?.[0] ?? BASE_ICON_SIZE[0] / 2) * config.size;
      const anchorY = (BASE_ICON_ANCHOR?.[1] ?? BASE_ICON_SIZE[1]) * config.size;
      icon.style.width = `${width}px`;
      icon.style.height = `${height}px`;
      icon.style.marginLeft = `${-anchorX}px`;
      icon.style.marginTop = `${-anchorY}px`;
      icon.style.opacity = config.opacity.toString();
    }
    const shadow = marker._shadow;
    if (shadow) {
      const shadowWidth = BASE_SHADOW_SIZE[0] * config.size;
      const shadowHeight = BASE_SHADOW_SIZE[1] * config.size;
      const shadowAnchorX =
        (BASE_SHADOW_ANCHOR?.[0] ?? BASE_SHADOW_SIZE[0] / 2) * config.size;
      const shadowAnchorY =
        (BASE_SHADOW_ANCHOR?.[1] ?? BASE_SHADOW_SIZE[1]) * config.size;
      shadow.style.width = `${shadowWidth}px`;
      shadow.style.height = `${shadowHeight}px`;
      shadow.style.marginLeft = `${-shadowAnchorX}px`;
      shadow.style.marginTop = `${-shadowAnchorY}px`;
      shadow.style.opacity = Math.min(1, Math.max(0, config.opacity * 0.9)).toString();
    }
  }

  function applyMarkerAppearanceToMarker(marker, mapKey) {
    const cfg = markerAppearance[mapKey];
