  }

  function buildGridRequest(computeResult, gridSettings) {
    if (!computeResult || !gridSettings) return null;
    const targetMapKey =
      computeResult.target && String(computeResult.target).toLowerCase() === "new"
        ? "new"
        : "old";
    const otherMapKey = targetMapKey === "old" ? "new" : "old";
    const showMaster = !!gridSettings.show;
    const overlayUndistorted = showMaster && !!gridSettings.showUndistorted;
    const showDistortedTarget = showMaster;
    const showUndistortedReference = showMaster;
    const links = buildGridLinks(computeResult);

    if (!showMaster) {
      return {
        request: null,
        fetchKey: null,
        targetMapKey,
        otherMapKey,
        settings: gridSettings,
        showDistortedTarget,
        showUndistortedReference,
        overlayUndistortedTarget: overlayUndistorted,
        linksCount: links.length,
      };
    }

    if (links.length < 3) {
      return {
        request: null,
        fetchKey: null,
        targetMapKey,
        otherMapKey,
        settings: gridSettings,
        showDistortedTarget,
        showUndistortedReference,
        overlayUndistortedTarget: overlayUndistorted,
        linksCount: links.length,
