    function renderSuggestions() {
      if (!suggestionTbody || !suggestionStatusEl || !suggestionEmptyEl) return;
      const state = suggestionState;
      if (suggestedLinks.length) {
        suggestionTbody.innerHTML = suggestedLinks.map(suggestionRowHtml).join("");
        suggestionEmptyEl.classList.add("hidden");
        suggestionEmptyEl.textContent = "";
      } else {
        suggestionTbody.innerHTML = "";
        suggestionEmptyEl.classList.remove("hidden");
        suggestionEmptyEl.textContent =
          state.status === "loading"
            ? "Analyzing maps to propose new links..."
            : 'No suggestions yet. Use "Suggest Links" to generate candidates.';
      }
      const statusParts = [];
      if (state.status === "loading") statusParts.push("Fetching suggestions...");
      if (suggestedLinks.length) {
        statusParts.push(
          `${suggestedLinks.length} suggestion${suggestedLinks.length === 1 ? "" : "s"} awaiting review.`
        );
      }
      if (state.message) statusParts.push(state.message);
      suggestionStatusEl.textContent = statusParts.join(" ");
      if (suggestionMessageEl) {
        if (state.error) {
          suggestionMessageEl.textContent = `Error: ${state.error}`;
        } else if (state.diagnostics) {
          const diag = state.diagnostics;
          const parts = [
            `kp_old=${diag.kp_old ?? 0}`,
            `kp_new=${diag.kp_new ?? 0}`,
            `matches=${diag.matches ?? 0}`,
            `good=${diag.good ?? diag.good_matches ?? 0}`,
            `inliers=${diag.inliers ?? 0}`,
            diag.seed_count != null ? `seeds=${diag.seed_count}` : null,
            diag.seed_inliers != null ? `seed_inliers=${diag.seed_inliers}` : null,
            diag.seed_consistent != null ? `seed_consistent=${diag.seed_consistent}` : null,
            diag.seed_expanded != null ? `seed_expanded=${diag.seed_expanded}` : null,
            diag.ocr_matches != null && diag.ocr_matches > 0
              ? `ocr=${diag.ocr_matches}/${diag.ocr_candidates ?? diag.ocr_matches}`
              : null,
            diag.min_distance != null && diag.min_distance > 0
              ? `min_dist=${diag.min_distance}${diag.min_distance_unit || ""}`
              : null,
            diag.max_suggestions != null ? `max=${diag.max_suggestions}` : null,
            diag.elapsed_ms != null ? `elapsed=${diag.elapsed_ms}ms` : null,
          ].filter(Boolean);
          suggestionMessageEl.textContent = parts.join(" · ");
        } else {
          suggestionMessageEl.textContent = "";
        }
        suggestionMessageEl.classList.toggle("text-red-400", !!state.error);
        suggestionMessageEl.classList.toggle("text-neutral-400", !state.error);
      }
      if (acceptAllBtn) {
        const disabled = !suggestedLinks.length;
        acceptAllBtn.classList.toggle("opacity-50", disabled);
        acceptAllBtn.classList.toggle("pointer-events-none", disabled);
      }
    }

    renderLinks();
    renderSuggestions();

    const uiListener = () => {
      renderLinks();
      renderSuggestions();
    };
    const escListener = (ev) => {
      if (ev.key === "Escape") cleanup();
    };
    let closed = false;
    const cleanup = () => {
      if (closed) return;
      closed = true;
      window.removeEventListener("mapanalyst:update-links-ui", uiListener);
      document.removeEventListener("keydown", escListener);
      modal.remove();
    };

    window.addEventListener("mapanalyst:update-links-ui", uiListener);
    document.addEventListener("keydown", escListener);
    modal.querySelector("#linked-modal-close")?.addEventListener("click", cleanup);
    modal.addEventListener("mousedown", (e) => {
      if (e.target.id === "linked-points-modal") cleanup();
    });

    linkTbody?.addEventListener("click", (ev) => {
      const button = ev.target.closest("button[data-action]");
      if (!button) return;
      const tr = button.closest("tr");
      if (!tr) return;
      const idx = Number(tr.dataset.idx);
      if (!Number.isFinite(idx)) return;
      const action = button.dataset.action;
      if (action === "rename") {
        const ln = links[idx];
        if (!ln) return;
        const name = prompt("Link name:", ln.name || "");
        if (name !== null) {
          ln.name = name.trim();
          pushHistory();
          emitLinkStateChanged();
          renderLinks();
        }
      } else if (action === "delete") {
        const ln = links[idx];
        if (!ln) return;
        links.splice(idx, 1);
        if (ln.old) selectedMarkers.add(ln.old);
        if (ln.new) selectedMarkers.add(ln.new);
        updateMarkerStyles();
        pushHistory();
        emitLinkStateChanged();
        clearSuggestions("data-changed");
        renderLinks();
      }
    });

    suggestionTbody?.addEventListener("click", (ev) => {
      const button = ev.target.closest("button[data-action]");
      if (!button) return;
      const id = button.dataset.id || button.closest("tr")?.dataset?.id;
      if (!id) return;
      if (button.dataset.action === "accept") {
        if (acceptSuggestionById(id)) {
          renderLinks();
          renderSuggestions();
        }
      } else if (button.dataset.action === "reject") {
        if (rejectSuggestionById(id)) {
          renderSuggestions();
        }
      }
    });

    acceptAllBtn?.addEventListener("click", () => {
      const ids = suggestedLinks.map((s) => s.id);
      if (!ids.length) return;
      ids.forEach((id) => acceptSuggestionById(id, { notify: false }));
      setSuggestionState({ message: "Accepted all available suggestions." });
      renderLinks();
      renderSuggestions();
    });

    refreshBtn?.addEventListener("click", () => {
      openSuggestionConfigModal("modal-refresh");
    });

    suggestBtn?.addEventListener("click", () => {
      openSuggestionConfigModal("modal-button");
    });
  });
  window.mapanalystGetState = () => {
    // oldMarkers/newMarkers/links are already defined in your file
    const oldPoints = oldMarkers.map((m) => {
      const { lat, lng } = m.getLatLng();
      return { lat, lng, name: m.__name || null };
    });
    const newPoints = newMarkers.map((m) => {
      const { lat, lng } = m.getLatLng();
      return { lat, lng, name: m.__name || null };
    });
    const mappedLinks = links.map((ln) => ({
      old_index: oldMarkers.indexOf(ln.old),
      new_index: newMarkers.indexOf(ln.new),
      name: ln.name || null,
    }));
    const polygons = {
      old: getPolygonCoordinates("old"),
      new: getPolygonCoordinates("new"),
      target: currentTargetMap,
      selectedKey: getSelectedPolygonKey(),
    };
    return { oldPoints, newPoints, links: mappedLinks, polygons };
  };

  window.mapanalystGetPolygons = () => ({
    old: getPolygonCoordinates("old"),
    new: getPolygonCoordinates("new"),
    target: currentTargetMap,
    selectedKey: getSelectedPolygonKey(),
  });
</script>




































