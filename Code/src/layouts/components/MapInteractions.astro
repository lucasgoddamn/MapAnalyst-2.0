  function parseThicknessToPixels(value) {
    if (typeof value !== "string") return 1.5;
    const num = Number.parseFloat(value);
    if (!Number.isFinite(num)) return 1.5;
    if (value.toLowerCase().includes("pt")) return num * 1.333; // 1pt ≈ 1.333px
