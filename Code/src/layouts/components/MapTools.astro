<div class="flex items-center bg-gray-100 dark:bg-gray-800 border-b border-gray-300 dark:border-gray-700 px-2 py-1 space-x-2">
  <!-- Compute -->
  <button id="btn-compute-maptools" title="Compute" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">🧮</span>
    <span class="text-sm">Compute</span>
  </button>

  <!-- Suggest Links -->
  <button
    id="btn-suggest-links"
    title="Suggest linked control points"
    class="flex items-center space-x-2 px-3 py-1 rounded border border-indigo-200 dark:border-indigo-700 bg-white dark:bg-gray-900 text-indigo-700 dark:text-indigo-200 hover:bg-indigo-100/80 dark:hover:bg-indigo-700/30 transition"
  >
    <svg
      aria-hidden="true"
      class="h-4 w-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M10.5 13.5L13.5 10.5" />
      <path d="M13.4 4.6l3-3a4.25 4.25 0 0 1 6 6l-3 3" />
      <path d="M4.6 13.4l-3 3a4.25 4.25 0 0 0 6 6l3-3" />
    </svg>
    <span class="text-sm font-medium">Suggest Links</span>
  </button>

  <!-- Rectangular Selection -->
  <button id="btn-select-rect" data-mode="select" title="Select Points (Rectangle)" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">◻️</span>
    <span class="text-sm">Select Rect</span>
  </button>

  <!-- Set New Point -->
  <button id="btn-new-point" data-mode="new" title="Set New Point" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">📍</span>
    <span class="text-sm">New Point</span>
  </button>

  <!-- Move Selected -->
  <button id="btn-move-point" data-mode="move" title="Move Selected Point" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">✋</span>
    <span class="text-sm">Move Point</span>
  </button>

  <!-- Delete Point -->
  <button id="btn-delete-point" data-mode="delete" title="Delete Point" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">🗑️</span>
    <span class="text-sm">Delete</span>
  </button>

  <!-- Measure Distance & Angle -->
  <button id="btn-measure" data-mode="measure" title="Measure Distance / Angle" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">📏</span>
    <span class="text-sm">Measure</span>
  </button>

  <!-- Draw Custom Polygon -->
  <button id="btn-draw-polygon" data-mode="polygon" title="Draw Custom Polygon" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">🔺</span>
    <span class="text-sm">Draw Polygon</span>
  </button>

  <!-- Show All -->
  <button id="btn-show-all" title="Show entire maps" class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700">
    <span aria-hidden="true" class="inline-flex items-center justify-center">🔍</span>
    <span class="text-sm">Show All</span>
  </button>

  <!-- Points Visibility -->
  <div class="relative">
    <button
      id="btn-points-visibility"
      title="Adjust point size and opacity"
      class="flex items-center space-x-1 px-3 py-1 rounded hover:bg-gray-200 dark:hover:bg-gray-700"
    >
      <span aria-hidden="true" class="inline-flex items-center justify-center">🎯</span>
      <span class="text-sm">Points Visibility</span>
    </button>
    <div
      id="points-visibility-popover"
      class="hidden absolute right-0 mt-2 w-60 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-lg z-[9999] p-3 space-y-3"
    >
      <div class="flex items-center justify-between text-sm font-medium">
        <span>Apply to:</span>
        <div class="flex items-center space-x-2 text-xs">
          <label class="flex items-center space-x-1 cursor-pointer">
            <input type="radio" name="pv-target" id="pv-target-old" value="old" />
            <span>Old</span>
          </label>
          <label class="flex items-center space-x-1 cursor-pointer">
            <input type="radio" name="pv-target" id="pv-target-new" value="new" />
            <span>New</span>
          </label>
          <label class="flex items-center space-x-1 cursor-pointer">
            <input type="radio" name="pv-target" id="pv-target-both" value="both" checked />
            <span>Both</span>
          </label>
        </div>
      </div>

      <div class="space-y-1">
        <div class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-300">
          <span>Point Size</span>
          <span id="pv-size-value">100%</span>
        </div>
        <input id="pv-size" type="range" min="0" max="100" value="100" class="w-full" />
      </div>

      <div class="space-y-1">
        <div class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-300">
          <span>Opacity</span>
          <span id="pv-opacity-value">100%</span>
        </div>
        <input id="pv-opacity" type="range" min="10" max="100" value="100" class="w-full" />
      </div>

      <div class="flex justify-end">
        <button id="pv-reset" class="text-xs text-blue-500 hover:text-blue-700 flex items-center space-x-1">
          <span aria-hidden="true" class="inline-flex items-center justify-center">↺</span>
          <span>Reset</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const attachMapToolsHandlers = () => {
    const computeBtn = document.getElementById("btn-compute-maptools");
    if (computeBtn && computeBtn.dataset.computeAttached !== "true") {
      computeBtn.addEventListener("click", () => {
        if (window.MapAnalyst?.doCompute) {
          window.MapAnalyst.doCompute();
        } else {
          document.getElementById("mi-compute")?.click();
        }
      });
      computeBtn.dataset.computeAttached = "true";
    }

    const showAllBtn = document.getElementById("btn-show-all");
    if (showAllBtn && showAllBtn.dataset.showAllAttached !== "true") {
      showAllBtn.addEventListener("click", () => {
        window.dispatchEvent(new CustomEvent("mapanalyst:show-all"));
      });
      showAllBtn.dataset.showAllAttached = "true";
    }

    const suggestBtn = document.getElementById("btn-suggest-links");
    if (suggestBtn && suggestBtn.dataset.suggestAttached !== "true") {
      suggestBtn.addEventListener("click", () => {
        window.dispatchEvent(
          new CustomEvent("mapanalyst:open-suggestion-config", {
            detail: { source: "maptools-toolbar" },
          })
        );
      });
      suggestBtn.dataset.suggestAttached = "true";
    }
  };
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", attachMapToolsHandlers, { once: true });
  } else {
    attachMapToolsHandlers();
  }
</script>


