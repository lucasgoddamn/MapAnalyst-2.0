---
import Base from "@/layouts/Base.astro";
import Cta from "@/layouts/components/Cta.astro";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import Toolbar from "@/layouts/components/Toolbar.astro";
import MapTools from "@/layouts/components/MapTools.astro";
import MapInteractions from "@/components/MapInteractions.astro";
import MapSettings from "@/layouts/components/MapSettings.astro";
import ComputeBridge from "@/layouts/components/ComputeBridge.astro";

const entry = (await getEntry(
  "mapanalyst",
  "-index"
)) as CollectionEntry<"mapanalyst">;
const { title, description, call_to_action } = entry.data;
---

<Base title={title} description={description}>
  <!-- Top Toolbar -->
  <Toolbar />

  <!-- Second toolbar: map tools -->
  <MapTools />

  <!-- Main Content Area -->
  <section class="section">
    <div class="mx-auto w-[90%]">
      <!-- Coordinate and measure readout -->
      <div class="flex justify-between mb-2 text-sm font-mono">
        <div>
          Old Map: X: <span id="oldMapX">-</span>, Y: <span id="oldMapY">-</span
          >
          <span style="margin-left:1em;">
            Distance: <span id="oldMapDistance">-</span>, Angle: <span
              id="oldMapAngle">-</span
            >
          </span>
        </div>
        <div>
          New Map: X: <span id="newMapX">-</span>, Y: <span id="newMapY">-</span
          >
          <span style="margin-left:1em;">
            Distance: <span id="newMapDistance">-</span>, Angle: <span
              id="newMapAngle">-</span
            >
          </span>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <!-- Left Section: Old Map -->
        <div class="border rounded-lg p-4">
          <h2 class="text-lg font-semibold mb-2">Old Map</h2>
          <input
            type="file"
            accept="image/*"
            id="oldMapInput"
            style="display: none;"
          />
          <div id="oldMapPreview" class="w-full h-[400px] mt-4"></div>
        </div>

        <!-- Right Section: New Map -->
        <div class="border rounded-lg p-4">
          <h2 class="text-lg font-semibold mb-2">New Map</h2>
          <div id="leafletMap" class="w-full h-[400px] border rounded-lg"></div>
          <input
            type="file"
            accept="image/*"
            id="newMapImageInput"
            style="display: none;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive map & upload logic -->
  <MapInteractions />
  <!-- Distortion / Displacement / Isolines settings panel -->
  <MapSettings />
  <ComputeBridge />

  <Cta cta={call_to_action} />
</Base>
